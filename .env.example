# Auth — pick ONE:
#   Option A: API key
ANTHROPIC_API_KEY=
#   Option B: Subscription token — run `claude setup-token` on host
CLAUDE_CODE_OAUTH_TOKEN=

# Repo — absolute path to the repo you want the agent to work on
REPO_PATH=/path/to/your/repo

# Agent config
MODEL=sonnet                    # Claude model to use
MAX_ITERATIONS=0                # 0 = infinite
LOOP_DELAY=5                    # Seconds between iterations
GIT_USER=agentmill              # Git commit author name
GIT_EMAIL=agent@agentmill       # Git commit author email
AUTO_COMMIT=wip                 # "off" | "wip" (safety-net) | "on" (always)
PUSH_REBASE_MAX_RETRIES=3       # Max rebase retries on push conflict
PROMPT_FILE=/prompts/PROMPT.md  # Default prompt file

# Multi-agent (only for agent-1/2/3 services)
AGENT_BRANCH=                   # Leave empty for auto (agent-$AGENT_ID)
PROMPT_FILE_1=/prompts/PROMPT.md
PROMPT_FILE_2=/prompts/PROMPT.md
PROMPT_FILE_3=/prompts/PROMPT.md

# Repo setup
AUTO_SETUP=true                 # Auto-detect and install dependencies
REPO_SETUP_COMMAND=             # Custom setup command (overrides auto-detect)
EXTRA_PYTHON_TOOLS=             # Additional pip packages to install

# TUI / Ralph Loop (watch & interactive services)
AUTO_RALPH=false                # Enable Ralph Loop in watch mode
AUTO_RALPH_MAX_ITERATIONS=10    # Ralph Loop iteration limit
AUTO_RALPH_COMPLETION_PROMISE=TASK_COMPLETE
RESPAWN=false                   # Restart TUI after exit
SKIP_PROMPT=false               # Skip initial prompt (interactive mode)

# Proxy / TLS (forwarded to container when set)
# HTTP_PROXY=
# HTTPS_PROXY=
# NO_PROXY=
# NODE_EXTRA_CA_CERTS=
