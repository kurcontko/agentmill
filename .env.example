# Auth — pick ONE:
#   Option A: API key
ANTHROPIC_API_KEY=
#   Option B: Subscription token — run `claude setup-token` on host
CLAUDE_CODE_OAUTH_TOKEN=
#   Other clients: set the provider key they expect
DASHSCOPE_API_KEY=
OPENAI_API_KEY=
CODEX_API_KEY=
CODEX_ACCESS_TOKEN=
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Repo — absolute path to the repo you want the agent to work on
REPO_PATH=/path/to/your/repo

# Agent config
AGENTMILL_CLIENT=claude          # Client executable: claude|codex|opencode|qwen|gemini. `fake` is test-only.
AGENTMILL_PROVIDER=              # Deprecated client-selection alias; reserve provider for model backend names.
AGENTMILL_CLIENT_TRANSPORT=native # native|acp. ACP is experimental for opencode/qwen watch/shell.
AGENTMILL_ACP_PROMPT=            # Optional one-turn prompt for AGENTMILL_CLIENT_TRANSPORT=acp.
AGENTMILL_CLIENT_HOME_ROOT=      # Optional root for isolated per-client config; defaults to $HOME/.agentmill/clients.
AGENTMILL_CLIENT_HOME=           # Optional absolute selected-client config home override.
AGENTMILL_OPENCODE_COMMAND=opencode # OpenCode binary path/command for AGENTMILL_CLIENT=opencode.
AGENTMILL_OPENCODE_REQUIRE_AUTH=true # Require a known provider key or auth file before OpenCode runs.
AGENTMILL_CODEX_COMMAND=codex    # Codex CLI binary path/command for AGENTMILL_CLIENT=codex.
AGENTMILL_CODEX_REQUIRE_AUTH=true # Require Codex/OpenAI env or trusted Codex auth before Codex runs.
AGENTMILL_CODEX_DEFAULT_MODEL=gpt-5.3-codex # Used when MODEL is still a Claude alias.
AGENTMILL_CODEX_SANDBOX=         # Optional legacy Codex sandbox override; empty uses AgentMill's generated Codex permission profile.
AGENTMILL_CODEX_APPROVAL_POLICY= # Optional Codex approval override; defaults to never for trusted, untrusted for standard/untrusted.
AGENTMILL_QWEN_COMMAND=qwen      # Qwen Code binary path/command for AGENTMILL_CLIENT=qwen.
AGENTMILL_QWEN_REQUIRE_AUTH=true # Require provider env or Qwen config/cache before Qwen runs.
AGENTMILL_QWEN_OUTPUT_FORMAT=stream-json # Qwen headless output: text|json|stream-json.
AGENTMILL_QWEN_INCLUDE_PARTIAL_MESSAGES=false # Include partial stream chunks for Qwen stream-json.
AGENTMILL_QWEN_DEFAULT_MODEL=qwen3-coder-plus # Used when MODEL is still a Claude alias.
AGENTMILL_QWEN_SANDBOX=          # Optional QWEN_SANDBOX override: true|false|docker|podman|sandbox-exec.
AGENTMILL_GEMINI_COMMAND=gemini  # Gemini CLI binary path/command for AGENTMILL_CLIENT=gemini.
AGENTMILL_GEMINI_REQUIRE_AUTH=true # Require Gemini/Google env or Gemini config/cache before Gemini runs.
AGENTMILL_GEMINI_OUTPUT_FORMAT=json # Gemini headless output: text|json.
AGENTMILL_GEMINI_DEFAULT_MODEL=gemini-2.5-flash # Used when MODEL is still a Claude alias.
AGENTMILL_GEMINI_SANDBOX=        # Optional GEMINI_SANDBOX override: true|false|docker|podman|sandbox-exec.
MODEL=opus                      # Claude model. Aliases: opus|sonnet|haiku resolve to the latest in each family.
                                # Versioned: opus-4.7, sonnet-4.6, haiku-4.5 (with -, ., or no separator).
                                # Or pin a full ID: claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5-20251001.
                                # See resolve_model() in entrypoint-common.sh.
AGENTMILL_ROLE=                 # Set by `mill run --agent ROLE`; optional for raw docker compose use.
AGENTMILL_PROFILE_LEVEL=trusted # trusted|standard|untrusted. trusted preserves current broad automation.
AGENTMILL_RUN_ID=               # Optional stable run id; defaults to timestamp-agent-pid.
AGENTMILL_FORWARD_HOST_MCP=     # Set true to forward host/project MCP outside trusted profile.
AGENTMILL_FORWARD_HOST_TOOLS=   # Set true to merge host allowedTools outside trusted profile.
AGENTMILL_FORWARD_HOST_HOOKS=   # Set true to merge host Claude hooks outside trusted profile.
AGENTMILL_FORWARD_HOST_ENV=     # Set true to merge host Claude env settings outside trusted profile.
AGENTMILL_FORWARD_HOST_EXTENSIONS= # Set true to copy host plugins, agents, commands, and allowlisted skills outside trusted profile.
AGENTMILL_MCP_ALLOWLIST=        # Comma-separated MCP servers allowed for standard/untrusted profiles.
AGENTMILL_MCP_MANIFEST_LOCK=true # For standard/untrusted, deny runs if MCP config hash changes after startup.
AGENTMILL_MCP_TOOL_SNAPSHOT=true # Include live stdio MCP tools/list description/schema hashes in the manifest lock when available.
AGENTMILL_MCP_TOOL_SNAPSHOT_TIMEOUT_SECONDS=3 # Timeout for each live MCP tools/list snapshot.
AGENTMILL_DOCTOR_REQUIRE_MCP_REACHABLE=false # Make `mill doctor` fail if latest MCP manifest commands are not reachable on PATH.
AGENTMILL_SKILL_ALLOWLIST=      # Comma-separated host skill directory names allowed for standard/untrusted profiles.
AGENTMILL_COMPLETION_GATE=      # Optional gate label. research_saturation requires zero-source streak and no open questions.
AGENTMILL_VERIFIER_COMMAND=     # Required by coder_verified/refactor_verified gates, e.g. "make test".
AGENTMILL_CODER_OPEN_QUESTIONS_MAX=0 # coder_verified requires unresolved open questions <= this count.
AGENTMILL_REFACTOR_LOC_TARGET=  # Optional signed target net line delta for refactor_verified, e.g. -20.
AGENTMILL_REFACTOR_LOC_TOLERANCE=0 # Non-negative tolerance around AGENTMILL_REFACTOR_LOC_TARGET.
AGENTMILL_REFACTOR_MAX_LOC_DELTA=0 # Used when no target is set; default prevents net LOC growth.
AGENTMILL_RESEARCH_SATURATION_ITERATIONS=3 # Stop research after this many consecutive zero-new-source iterations.
AGENTMILL_RESEARCH_OPEN_QUESTIONS_MAX=0    # Research completion requires unresolved open questions <= this count.
AGENTMILL_NETWORK=              # Optional network policy: allow|allowlist|deny. deny disables Docker networking; allowlist uses the egress proxy below.
AGENTMILL_EGRESS_ALLOWLIST=     # Comma-separated HTTP(S) proxy targets for AGENTMILL_NETWORK=allowlist, e.g. "api.anthropic.com,github.com,*.githubusercontent.com".
AGENTMILL_EGRESS_PROXY_PORT=18080 # Internal proxy listen port used for AGENTMILL_NETWORK=allowlist.
AGENTMILL_HOOK_DIR=/hooks       # Harness-owned hook directory mounted read-only into containers.
AGENTMILL_HOOK_TIMEOUT_SECONDS=30
AGENTMILL_HOOK_CONTEXT_MAX_BYTES=16384 # Max pre_iteration additional_context bytes injected into the next prompt.
AGENTMILL_ALLOW_HIGH_RISK_CHANGES=false # Set true to let standard/untrusted runs commit CI, MCP, auth, deploy, or package-script changes.
AGENTMILL_WORKSPACE_MODE=auto   # auto|direct|readonly-clone. `mill run` auto-selects readonly-clone for standard/untrusted unless direct is explicitly allowed.
AGENTMILL_ALLOW_DIRECT_HOST_REPO=false # Set true to permit standard/untrusted direct writable host repo mounts.
AGENTMILL_READ_ONLY_ROOTFS=true  # Keep container root filesystem read-only; runtime scratch paths use tmpfs.
AGENTMILL_WRITE_ROOTS=          # Optional comma-separated repo-relative durable write roots, e.g. "src,tests,docs"; enforced by gates, native policy, and bwrap for non-native clients.
AGENTMILL_WRITE_ROOT_SANDBOX=auto # auto|bwrap|off. Uses bwrap to enforce write roots for OpenCode/Qwen/Gemini when needed.
AGENTMILL_BWRAP_COMMAND=bwrap   # Bubblewrap command used by AGENTMILL_WRITE_ROOT_SANDBOX.
AGENTMILL_PRETOOL_POLICY_COMMAND=/agentmill-pretool-policy.py # Claude PreToolUse policy hook command inside the container.
AGENTMILL_SHELL_ALLOWLIST=      # Optional comma-separated Claude Bash permission patterns to allow, e.g. "git status:*,make test:*".
AGENTMILL_SHELL_DENYLIST=       # Optional comma-separated extra Claude Bash permission patterns, e.g. "make deploy:*,gh release:*".
AGENTMILL_ALLOW_SHELL_NETWORK=false # Set true to allow curl/wget/nc-style Bash network clients outside trusted profiles.
AGENTMILL_PROTECTED_BRANCHES=main,master,trunk,release,production
AGENTMILL_ALLOW_PROTECTED_BRANCH_WRITES=false # Set true to let standard/untrusted direct/push modes write protected branches.
AGENTMILL_ALLOW_FORCE_PUSH=false     # Set true only for supervised runs that intentionally allow force-push.
AGENTMILL_ALLOW_MERGE_COMMITS=false  # Set true only for supervised standard/untrusted runs that intentionally create merge commits.
AGENTMILL_GIT_REMOTE_ALLOWLIST=      # Comma-separated network git remotes allowed for harness fetch/rebase/push, e.g. github.com/org/repo.
AGENTMILL_ALLOW_GIT_NETWORK=false    # Set true to permit harness git network remotes when AGENTMILL_NETWORK=deny.
MAX_ITERATIONS=0                # 0 = infinite
MAX_WALL_SECONDS=0              # 0 = no wall-clock limit. Required for unbounded standard/untrusted respawn runs.
MAX_LOG_BYTES=0                 # 0 = no log-size limit. Set for overnight runs to stop before logs grow without bound.
MAX_TOTAL_TOKENS=0              # 0 = no token budget. Requires usage telemetry from JSON output.
MAX_TOTAL_USD=0                 # 0 = no cost budget. Requires usage telemetry from JSON output.
AGENTMILL_COST_INPUT_PER_MTOKENS=0 # Optional cost estimator rate per 1M input tokens when client output lacks cost_usd.
AGENTMILL_COST_OUTPUT_PER_MTOKENS=0 # Optional cost estimator rate per 1M output/reasoning tokens.
AGENTMILL_COST_CACHE_CREATION_PER_MTOKENS=0 # Optional cost estimator rate per 1M cache-write tokens.
AGENTMILL_COST_CACHE_READ_PER_MTOKENS=0 # Optional cost estimator rate per 1M cache-read tokens.
AGENTMILL_CLAUDE_OUTPUT_FORMAT=text # text|json|stream-json. Use json/stream-json to parse Claude usage telemetry when supported.
LOOP_DELAY=5                    # Seconds between iterations
GIT_USER=agentmill              # Git commit author name
GIT_EMAIL=mikeqrc@gmail.com     # Git commit author email
AUTO_COMMIT=wip                 # "off" | "wip" (safety-net) | "on" (always)
PUSH_REBASE_MAX_RETRIES=3       # Max rebase retries on push conflict
PROMPT_FILE=/prompts/PROMPT.md  # Default prompt file

# Multi-agent (only for agent-1/2/3 services)
AGENT_BRANCH=                   # Leave empty for auto (agent-$AGENT_ID)
PROMPT_FILE_1=/prompts/PROMPT.md
PROMPT_FILE_2=/prompts/PROMPT.md
PROMPT_FILE_3=/prompts/PROMPT.md

# Repo setup
AUTO_SETUP=true                 # Auto-detect and install dependencies
AUTO_SETUP_LANGUAGES=all        # all or comma-separated: make,python,node,go,rust
REPO_SETUP_COMMAND=             # Custom setup command (overrides auto-detect)
EXTRA_PYTHON_TOOLS=             # Additional pip packages to install

# TUI / Ralph Loop (watch & interactive services)
AUTO_RALPH=false                # Enable Ralph Loop in watch mode
AUTO_RALPH_MAX_ITERATIONS=10    # Ralph Loop iteration limit
AUTO_RALPH_COMPLETION_PROMISE=TASK_COMPLETE
RESPAWN=false                   # Restart TUI after exit
SKIP_PROMPT=false               # Skip initial prompt (interactive mode)

# Proxy / TLS (forwarded to container when set)
# HTTP_PROXY=
# HTTPS_PROXY=
# NO_PROXY=
# NODE_EXTRA_CA_CERTS=
