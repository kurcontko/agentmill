# Engine — which CLI backend to use
ENGINE=claude                   # "claude" or "opencode"

# Auth — pick ONE:
#   Option A: API key (works with both engines)
ANTHROPIC_API_KEY=
#   Option B: Subscription token (claude engine only) — run `claude setup-token` on host
CLAUDE_CODE_OAUTH_TOKEN=

# Repo source (set ONE of these, or mount a local repo at ./repo)
REPO_URL=https://github.com/you/your-repo.git

# Optional
MODEL=sonnet                    # Model to use (claude: "sonnet", opencode: "anthropic/claude-sonnet-4-5")
MAX_ITERATIONS=0                # 0 = infinite
LOOP_DELAY=5                    # Seconds between iterations
GIT_USER=agentmill              # Git commit author name
GIT_EMAIL=agent@agentmill       # Git commit author email
