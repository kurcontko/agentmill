        doctor_warn env "both ANTHROPIC_API_KEY and CLAUDE_CODE_OAUTH_TOKEN are set; ANTHROPIC_API_KEY takes precedence"
    fi
}

doctor_validate_profiles() {
    local profiles_dir="$MILL_DIR/agents" renderer="$MILL_DIR/scripts/profile-env.py"
    local file role output rc count=0 invalid=0
    if [[ ! -d "$profiles_dir" ]]; then
        doctor_warn profile "agents directory missing; built-in role validation skipped"
        return 0
    fi
    if [[ ! -f "$renderer" ]]; then
        doctor_warn profile "profile renderer missing; built-in role validation skipped"
        return 0
    fi
    for file in "$profiles_dir"/*.toml; do
        [[ -f "$file" ]] || continue
        count=$((count + 1))
        role="$(basename "$file" .toml)"
        set +e
        output="$(python3 "$renderer" "$file" --role "$role" --agent-id 1 2>&1 >/dev/null)"
        rc=$?
        set -e
        if [[ "$rc" -ne 0 ]]; then
            invalid=$((invalid + 1))
            output="${output//$'\n'/ }"
            doctor_error profile "invalid $role.toml: ${output:-profile-env failed}"
        fi
    done
    if [[ "$count" -eq 0 ]]; then
        doctor_warn profile "no agents/*.toml profiles found"
    elif [[ "$invalid" -eq 0 ]]; then
        doctor_ok profile "validated $count role profile(s)"
    fi
}

doctor_validate_mcp_manifest() {
    local profile_level="$1" mcp_allowlist="$2" forward_mcp="$3" manifest require_reachable
    manifest="$(mcp_latest_manifest)"
    require_reachable="${AGENTMILL_DOCTOR_REQUIRE_MCP_REACHABLE:-false}"

    while IFS=$'\t' read -r status topic detail; do
        [[ -n "${status:-}" ]] || continue
        case "$status" in
            OK) doctor_ok "$topic" "$detail" ;;
            WARN) doctor_warn "$topic" "$detail" ;;
            ERROR) doctor_error "$topic" "$detail" ;;
        esac
    done < <(python3 - "$manifest" "$profile_level" "$mcp_allowlist" "$forward_mcp" "$require_reachable" <<'PY'
import json
import os
import shutil
import sys
from pathlib import Path

manifest_path, profile, allowlist_raw, forward_mcp, require_reachable = sys.argv[1:6]

def truthy(value: str) -> bool:
    return value.lower() in {"1", "true", "yes", "on"}

def emit(status: str, detail: str) -> None:
    print(f"{status}\tmcp\t{detail}")

allowlist = [item.strip() for item in allowlist_raw.split(",") if item.strip()]
allowset = set(allowlist)
strict_reachable = truthy(require_reachable)
mcp_expected = bool(allowset) or truthy(forward_mcp) or profile == "trusted"

if not mcp_expected:
    emit("OK", "no MCP manifest snapshot required without forwarded or allowlisted MCP")
    raise SystemExit(0)

if not manifest_path:
    status = "ERROR" if strict_reachable else "WARN"
    emit(status, "no MCP manifest snapshot found; run an agent once to verify MCP reachability")
    raise SystemExit(0)

path = Path(manifest_path)
try:
    manifest = json.loads(path.read_text())
except (OSError, json.JSONDecodeError) as exc:
    emit("ERROR", f"could not read latest MCP manifest {path}: {exc}")
    raise SystemExit(0)

servers = [server for server in manifest.get("servers", []) if isinstance(server, dict)]
names = {str(server.get("name", "")) for server in servers if server.get("name")}
manifest_profile = str(manifest.get("profile", ""))
manifest_allowset = {
    item.strip()
    for item in manifest.get("mcp_allowlist", [])
    if isinstance(item, str) and item.strip()
}
manifest_current = manifest_profile == profile and manifest_allowset == allowset

if not manifest_current:
    emit(
        "WARN",
        f"latest MCP manifest is for profile={manifest_profile or 'unknown'} allowlist={','.join(sorted(manifest_allowset)) or '<empty>'}; run an agent to refresh it",
    )
else:
    if profile != "trusted":
        if allowset:
            missing = sorted(allowset - names)
            unexpected = sorted(names - allowset)
            if missing:
                emit("ERROR", f"allowlisted MCP server missing from latest manifest: {','.join(missing)}")
            else:
                emit("OK", f"latest manifest includes allowlisted MCP server(s): {','.join(allowlist)}")
            if unexpected:
                emit("ERROR", f"latest manifest includes MCP server(s) outside allowlist: {','.join(unexpected)}")
        elif names:
            emit("ERROR", f"latest manifest includes MCP server(s) but current profile has no allowlist: {','.join(sorted(names))}")
        else:
            emit("OK", "latest manifest has no MCP servers for current profile")
    elif names:
        emit("OK", f"latest manifest includes {len(names)} trusted MCP server(s)")
    else:
        emit("OK", "latest manifest has no MCP servers")

def reachability(server: dict) -> tuple[bool, str]:
    name = str(server.get("name", "unknown"))
    transport = str(server.get("transport", "unknown"))
    if transport == "stdio":
        command = str(server.get("command", "")).strip()
        if not command:
            return False, f"{name} stdio command metadata is missing"
        if command.startswith("/"):
            if os.access(command, os.X_OK):
                return True, f"{name} stdio command reachable: {command}"
            return False, f"{name} stdio command not reachable: {command}"
        if shutil.which(command) is not None:
            return True, f"{name} stdio command reachable: {command}"
        return False, f"{name} stdio command not reachable: {command}"
    if transport in {"remote", "http", "sse", "streamable-http"} or server.get("url_host"):
        scheme = str(server.get("url_scheme", "")).strip()
        host = str(server.get("url_host", "")).strip()
        if scheme and host:
            return True, f"{name} remote endpoint configured: {scheme}://{host}"
        return False, f"{name} remote endpoint metadata is incomplete"
    return False, f"{name} has unsupported MCP transport metadata: {transport}"

selected = [server for server in servers if not allowset or str(server.get("name", "")) in allowset]
if not selected:
    if mcp_expected and manifest_current:
        emit("WARN", "latest MCP manifest has no configured servers to check")
    raise SystemExit(0)

tool_snapshot_enabled = manifest.get("tool_snapshot_enabled") is True
for server in selected:
    ok, detail = reachability(server)
    if ok:
        emit("OK", detail)
    else:
        emit("ERROR" if strict_reachable else "WARN", detail)
    if tool_snapshot_enabled:
        name = str(server.get("name", "unknown"))
        snapshot_status = str(server.get("tool_snapshot_status", "")).strip()
        if snapshot_status == "ok":
            emit("OK", f"{name} MCP tool snapshot includes {server.get('tool_count', 0) or 0} tool(s)")
        elif snapshot_status and snapshot_status != "disabled":
            emit("WARN", f"{name} MCP tool snapshot unavailable: {snapshot_status}")
PY
)
}

cmd_doctor() {
    local repo="" profile_level="${AGENTMILL_PROFILE_LEVEL:-trusted}" fix=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --fix) fix=true; shift ;;
            --profile-level) profile_level="$2"; shift 2 ;;
            --repo) repo="$2"; shift 2 ;;
            *) repo="${repo:-$1}"; shift ;;
        esac
    done

    DOCTOR_ERRORS=0
    DOCTOR_WARNINGS=0

    if [[ "$fix" == true ]]; then
        [[ -f "$MILL_DIR/.env" ]] || cp "$MILL_DIR/.env.example" "$MILL_DIR/.env"
        mkdir -p "$MILL_DIR/logs" "$MILL_DIR/memory" "$MILL_DIR/hooks" "$MILL_DIR/prompts"
        if [[ ! -f "$MILL_DIR/prompts/PROMPT.md" ]]; then
            cat > "$MILL_DIR/prompts/PROMPT.md" <<'PROMPT'
# AgentMill Task

Read `TASK.md` for your mission. If it doesn't exist, read `PROGRESS.md` and pick the next item.

**Run `touch /tmp/.agentmill-done` when finished.**
PROMPT
        fi
        doctor_ok fix "ensured .env, prompts, logs, memory, and hooks exist"
    fi

    case "$profile_level" in
        trusted|standard|untrusted) doctor_ok profile "AGENTMILL_PROFILE_LEVEL=$profile_level" ;;
        *) doctor_error profile "invalid AGENTMILL_PROFILE_LEVEL=$profile_level (expected trusted, standard, or untrusted)" ;;
    esac
    local selected_client="${AGENTMILL_CLIENT:-claude}" codex_approval="${AGENTMILL_CODEX_APPROVAL_POLICY:-}" codex_sandbox="${AGENTMILL_CODEX_SANDBOX:-}"
    if [[ "$selected_client" == "codex" && "$profile_level" != "trusted" ]]; then
        if [[ -z "$codex_approval" ]]; then
            doctor_ok client "Codex non-trusted runs default to approval_policy=untrusted with generated permission profile and execpolicy rules"
        elif [[ "$codex_approval" == "never" ]]; then
            doctor_error client "AGENTMILL_CLIENT=codex outside trusted must not use AGENTMILL_CODEX_APPROVAL_POLICY=never"
        else
            doctor_ok client "Codex approval policy override: $codex_approval"
        fi
        if [[ -n "$codex_sandbox" && -n "${AGENTMILL_WRITE_ROOTS:-}" ]]; then
            doctor_error client "AGENTMILL_CODEX_SANDBOX bypasses generated Codex permission-profile write roots; unset it or omit AGENTMILL_WRITE_ROOTS"
        fi
    fi
    doctor_validate_profiles

    doctor_validate_env_schema

    if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
        doctor_ok auth "ANTHROPIC_API_KEY is set"
    elif [[ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]]; then
        doctor_ok auth "CLAUDE_CODE_OAUTH_TOKEN is set"
    else
        doctor_error auth "set ANTHROPIC_API_KEY or CLAUDE_CODE_OAUTH_TOKEN"
    fi

    doctor_model_floor_check

    if doctor_truthy "${AGENTMILL_DOCTOR_SKIP_DOCKER:-false}"; then
        doctor_warn docker "docker checks skipped by AGENTMILL_DOCTOR_SKIP_DOCKER"
    elif command -v docker >/dev/null 2>&1; then
        if docker info >/dev/null 2>&1; then
            doctor_ok docker "daemon is reachable"
        else
            doctor_error docker "daemon is not reachable"
        fi
        if docker compose version >/dev/null 2>&1 || command -v docker-compose >/dev/null 2>&1; then
            doctor_ok compose "docker compose is available"
        else
            doctor_error compose "docker compose plugin or docker-compose binary is missing"
        fi
        if docker image inspect agentmill >/dev/null 2>&1; then
            doctor_ok image "agentmill image exists"
            local image_created=""
            image_created="$(docker image inspect agentmill --format '{{.Created}}' 2>/dev/null || true)"
            if [[ -n "$image_created" && -f "$MILL_DIR/Dockerfile" ]]; then
                if python3 - "$MILL_DIR/Dockerfile" "$image_created" <<'PY'
from __future__ import annotations

import sys
from datetime import datetime, timezone
from pathlib import Path

dockerfile = Path(sys.argv[1])
raw = sys.argv[2].strip()
if raw.endswith("Z"):
    raw = raw[:-1] + "+00:00"
if "." in raw:
    head, tail = raw.split(".", 1)
    suffix = ""
    if "+" in tail:
        frac, tz = tail.split("+", 1)
        suffix = "+" + tz
    elif "-" in tail:
        frac, tz = tail.split("-", 1)
        suffix = "-" + tz
    else:
        frac = tail
    raw = f"{head}.{frac[:6]}{suffix}"

try:
    created = datetime.fromisoformat(raw)
except ValueError:
    raise SystemExit(2)
if created.tzinfo is None:
    created = created.replace(tzinfo=timezone.utc)
created_ts = created.timestamp()
raise SystemExit(0 if created_ts >= dockerfile.stat().st_mtime else 1)
PY
                then
                    doctor_ok image "agentmill image is newer than Dockerfile"
                else
                    doctor_warn image "agentmill image may be older than Dockerfile; run 'mill build --pull' or 'mill build'"
                fi
            else
                doctor_warn image "could not determine agentmill image freshness"
            fi
        else
            doctor_warn image "agentmill image not found; run 'mill build'"
        fi
    else
        doctor_error docker "docker command is not installed or not on PATH"
    fi

    repo="${repo:-${REPO_PATH:-}}"
    if [[ -z "$repo" ]]; then
        doctor_error repo "set REPO_PATH or pass a repo path"
    else
        [[ "$repo" == /* ]] || repo="$PWD/$repo"
        if [[ -d "$repo/.git" ]] || [[ -f "$repo/.git" ]]; then
            doctor_ok repo "$repo is a git repo"
            if [[ -O "$repo" ]]; then
                doctor_ok ownership "current user owns repo path"
            else
                doctor_warn ownership "current user does not own repo path"
            fi
            if [[ "$profile_level" != "trusted" && -w "$repo" ]]; then
                doctor_warn isolation "standard/untrusted single-agent runs currently use a writable repo mount; prefer multi-agent isolated clone mode for higher-risk work"
            fi
            local branch
            branch="$(git -C "$repo" branch --show-current 2>/dev/null || true)"
            if [[ -n "$branch" ]]; then
                doctor_ok git "current branch is $branch"
            else
                doctor_warn git "repo appears to be detached or branch could not be detected"
            fi
            if git -C "$repo" remote get-url origin >/dev/null 2>&1; then
                doctor_ok remote "origin remote is configured"
            else
                doctor_warn remote "origin remote is not configured; multi-agent push/fetch workflows may be limited"
            fi
            if [[ -n "$(git -C "$repo" status --porcelain 2>/dev/null)" ]]; then
                doctor_warn worktree "repo has uncommitted changes"
            else
                doctor_ok worktree "repo is clean"
            fi
        else
            doctor_error repo "$repo is not a git repo"
        fi
    fi

    local prompt_file="${PROMPT_FILE:-/prompts/PROMPT.md}" host_prompt
    host_prompt="$(doctor_host_prompt_path "$prompt_file")"
    if [[ -f "$host_prompt" ]]; then
        doctor_ok prompt "$prompt_file maps to $host_prompt"
    else
        doctor_error prompt "$prompt_file does not exist on host at $host_prompt"
    fi

    local max_iterations="${MAX_ITERATIONS:-0}" max_wall="${MAX_WALL_SECONDS:-0}" max_log="${MAX_LOG_BYTES:-0}" max_tokens="${MAX_TOTAL_TOKENS:-0}" max_usd="${MAX_TOTAL_USD:-0}"
    if doctor_nonnegative_int "$max_iterations"; then
        doctor_ok budget "MAX_ITERATIONS=$max_iterations"
    else
        doctor_error budget "MAX_ITERATIONS must be a non-negative integer"
    fi
    if doctor_nonnegative_int "$max_wall"; then
        doctor_ok budget "MAX_WALL_SECONDS=$max_wall"
    else
        doctor_error budget "MAX_WALL_SECONDS must be a non-negative integer"
    fi
    if doctor_nonnegative_int "$max_log"; then
        doctor_ok budget "MAX_LOG_BYTES=$max_log"
    else
        doctor_error budget "MAX_LOG_BYTES must be a non-negative integer"
    fi
    if doctor_nonnegative_int "$max_tokens"; then
        doctor_ok budget "MAX_TOTAL_TOKENS=$max_tokens"
    else
        doctor_error budget "MAX_TOTAL_TOKENS must be a non-negative integer"
    fi
    if [[ "$max_usd" =~ ^[0-9]+([.][0-9]+)?$ ]]; then
        doctor_ok budget "MAX_TOTAL_USD=$max_usd"
    else
        doctor_error budget "MAX_TOTAL_USD must be a non-negative number"
    fi
    if [[ "$profile_level" != "trusted" ]] && doctor_nonnegative_int "$max_iterations" && doctor_nonnegative_int "$max_wall"; then
        if [[ "$max_iterations" -eq 0 && "$max_wall" -eq 0 ]]; then
            doctor_error budget "standard/untrusted runs require MAX_ITERATIONS or MAX_WALL_SECONDS"
        fi
    elif [[ "$profile_level" == "trusted" && "$max_iterations" =~ ^[0-9]+$ && "$max_wall" =~ ^[0-9]+$ ]]; then
        if [[ "$max_iterations" -eq 0 && "$max_wall" -eq 0 ]]; then
            doctor_warn budget "trusted run is unbounded by iteration or wall-clock time"
        fi
    fi

    local completion_gate="${AGENTMILL_COMPLETION_GATE:-done_file}" verifier_command="${AGENTMILL_VERIFIER_COMMAND:-}"
    local coder_open="${AGENTMILL_CODER_OPEN_QUESTIONS_MAX:-0}" refactor_target="${AGENTMILL_REFACTOR_LOC_TARGET:-}" refactor_tolerance="${AGENTMILL_REFACTOR_LOC_TOLERANCE:-0}" refactor_max_delta="${AGENTMILL_REFACTOR_MAX_LOC_DELTA:-0}"
    case "$completion_gate" in
        coder_*|coding_*|coder_verified|coding_verified)
            if [[ -n "$verifier_command" ]]; then
                doctor_ok completion "coder gate has AGENTMILL_VERIFIER_COMMAND"
            else
                doctor_error completion "coder_verified requires AGENTMILL_VERIFIER_COMMAND"
            fi
            if doctor_nonnegative_int "$coder_open"; then
                doctor_ok completion "AGENTMILL_CODER_OPEN_QUESTIONS_MAX=$coder_open"
            else
                doctor_error completion "AGENTMILL_CODER_OPEN_QUESTIONS_MAX must be a non-negative integer"
            fi
            ;;
        refactor_*|refactor_verified)
            if [[ -n "$verifier_command" ]]; then
                doctor_ok completion "refactor gate has AGENTMILL_VERIFIER_COMMAND"
            else
                doctor_error completion "refactor_verified requires AGENTMILL_VERIFIER_COMMAND"
            fi
            if [[ -n "$refactor_target" ]]; then
                if doctor_signed_int "$refactor_target"; then
                    doctor_ok completion "AGENTMILL_REFACTOR_LOC_TARGET=$refactor_target"
                else
                    doctor_error completion "AGENTMILL_REFACTOR_LOC_TARGET must be a signed integer"
                fi
                if doctor_nonnegative_int "$refactor_tolerance"; then
                    doctor_ok completion "AGENTMILL_REFACTOR_LOC_TOLERANCE=$refactor_tolerance"
                else
                    doctor_error completion "AGENTMILL_REFACTOR_LOC_TOLERANCE must be a non-negative integer"
                fi
            elif doctor_signed_int "$refactor_max_delta"; then
                doctor_ok completion "AGENTMILL_REFACTOR_MAX_LOC_DELTA=$refactor_max_delta"
            else
                doctor_error completion "AGENTMILL_REFACTOR_MAX_LOC_DELTA must be a signed integer"
            fi
            ;;
        research_*|source_saturation|research_saturation)
            if doctor_nonnegative_int "${AGENTMILL_RESEARCH_SATURATION_ITERATIONS:-3}" && [[ "${AGENTMILL_RESEARCH_SATURATION_ITERATIONS:-3}" -gt 0 ]]; then
                doctor_ok completion "research saturation iterations=${AGENTMILL_RESEARCH_SATURATION_ITERATIONS:-3}"
            else
                doctor_error completion "AGENTMILL_RESEARCH_SATURATION_ITERATIONS must be a positive integer"
            fi
            if doctor_nonnegative_int "${AGENTMILL_RESEARCH_OPEN_QUESTIONS_MAX:-0}"; then
                doctor_ok completion "research open-question max=${AGENTMILL_RESEARCH_OPEN_QUESTIONS_MAX:-0}"
            else
                doctor_error completion "AGENTMILL_RESEARCH_OPEN_QUESTIONS_MAX must be a non-negative integer"
            fi
            ;;
        ""|done_file|sentinel)
            doctor_ok completion "completion gate: ${completion_gate:-done_file}"
            ;;
        *)
            doctor_warn completion "unknown completion gate '$completion_gate' falls back to done_file"
            ;;
    esac

    local network="${AGENTMILL_NETWORK:-}" git_remote_allowlist="${AGENTMILL_GIT_REMOTE_ALLOWLIST:-}" allow_git_network="${AGENTMILL_ALLOW_GIT_NETWORK:-false}" egress_allowlist="${AGENTMILL_EGRESS_ALLOWLIST:-}"
    case "$network" in
        "" ) doctor_warn network "AGENTMILL_NETWORK is unset; container egress is unrestricted" ;;
        allow) doctor_warn network "AGENTMILL_NETWORK=allow; container egress is unrestricted" ;;
        allowlist)
            if [[ -n "$egress_allowlist" ]]; then
                doctor_ok network "container egress proxy allowlist is set: $egress_allowlist"
                doctor_ok network "mill-launched services use Docker internal proxy network for allowlist egress"
            else
                doctor_error network "AGENTMILL_NETWORK=allowlist requires AGENTMILL_EGRESS_ALLOWLIST"
            fi
            if [[ -n "$git_remote_allowlist" ]]; then
                doctor_ok network "harness git remote allowlist is set: $git_remote_allowlist"
            else
                doctor_warn network "AGENTMILL_NETWORK=allowlist has no AGENTMILL_GIT_REMOTE_ALLOWLIST; network git origins will be denied by harness git policy"
            fi
            ;;
        deny)
            if doctor_truthy "$allow_git_network"; then
                if [[ -n "$git_remote_allowlist" ]]; then
                    doctor_warn network "AGENTMILL_NETWORK=deny but harness git network remotes are allowed for: $git_remote_allowlist"
                else
                    doctor_warn network "AGENTMILL_NETWORK=deny but AGENTMILL_ALLOW_GIT_NETWORK=true allows harness git network remotes without an allowlist"
                fi
            else
                doctor_ok network "harness-managed git network remotes are denied"
            fi
            doctor_ok network "mill-launched services use Docker network_mode=none"
            ;;
        *) doctor_error network "invalid AGENTMILL_NETWORK=$network (expected allow, allowlist, or deny)" ;;
    esac
    if [[ "$network" != "allowlist" && "$network" != "deny" && -n "$git_remote_allowlist" ]]; then
        doctor_ok network "harness git remote allowlist is set: $git_remote_allowlist"
    fi

    local mcp_allowlist="${AGENTMILL_MCP_ALLOWLIST:-}" forward_mcp="${AGENTMILL_FORWARD_HOST_MCP:-}"
    if [[ "$profile_level" != "trusted" ]] && doctor_truthy "$forward_mcp" && [[ -z "$mcp_allowlist" ]]; then
        doctor_error mcp "AGENTMILL_FORWARD_HOST_MCP=true outside trusted requires AGENTMILL_MCP_ALLOWLIST"
    elif [[ "$profile_level" != "trusted" && -z "$mcp_allowlist" ]]; then
        doctor_ok mcp "host/project MCP forwarding is disabled by default"
    elif [[ -n "$mcp_allowlist" && "$mcp_allowlist" == *"*"* ]]; then
        doctor_error mcp "AGENTMILL_MCP_ALLOWLIST must name explicit servers, not wildcards"
    elif [[ -n "$mcp_allowlist" ]]; then
        doctor_ok mcp "allowlist: $mcp_allowlist"
    else
        doctor_ok mcp "trusted profile may forward host/project MCP"
    fi
    doctor_validate_mcp_manifest "$profile_level" "$mcp_allowlist" "$forward_mcp"

    local high_risk="${AGENTMILL_ALLOW_HIGH_RISK_CHANGES:-false}"
    if [[ "$profile_level" != "trusted" ]] && doctor_truthy "$high_risk"; then
        doctor_warn policy "AGENTMILL_ALLOW_HIGH_RISK_CHANGES permits high-risk commits for $profile_level profile"
    else
        doctor_ok policy "high-risk change gate default is active"
    fi

    local forwarded_host_config=()
    [[ "$profile_level" != "trusted" ]] && doctor_truthy "${AGENTMILL_FORWARD_HOST_TOOLS:-}" && forwarded_host_config+=("tools")
    [[ "$profile_level" != "trusted" ]] && doctor_truthy "${AGENTMILL_FORWARD_HOST_HOOKS:-}" && forwarded_host_config+=("hooks")
    [[ "$profile_level" != "trusted" ]] && doctor_truthy "${AGENTMILL_FORWARD_HOST_ENV:-}" && forwarded_host_config+=("env")
    [[ "$profile_level" != "trusted" ]] && doctor_truthy "${AGENTMILL_FORWARD_HOST_EXTENSIONS:-}" && forwarded_host_config+=("extensions")
    if [[ "${#forwarded_host_config[@]}" -gt 0 ]]; then
        doctor_warn host-config "forwarding host ${forwarded_host_config[*]} outside trusted profile"
    elif [[ "$profile_level" != "trusted" ]]; then
        doctor_ok host-config "host tools, hooks, env, plugins, skills, agents, and commands are not forwarded by default"
    else
        doctor_ok host-config "trusted profile may forward host Claude config"
    fi
    local missing_host_mounts=() expected_mount
    for expected_mount in \
        '/home/agent/.host-claude.json:ro' \
        '/home/agent/.claude/settings.host.json:ro' \
        '/home/agent/.host-plugins:ro' \
        '/home/agent/.host-skills:ro' \
        '/home/agent/.host-agents:ro' \
        '/home/agent/.host-commands:ro'; do
        grep -qF "$expected_mount" "$MILL_DIR/docker-compose.yml" 2>/dev/null || missing_host_mounts+=("$expected_mount")
    done
    if [[ "${#missing_host_mounts[@]}" -gt 0 ]]; then
        doctor_warn host-config "could not verify read-only host Claude mounts: ${missing_host_mounts[*]}"
    else
        doctor_ok host-config "compose mounts host Claude config and extensions read-only"
    fi

    local skill_allowlist="${AGENTMILL_SKILL_ALLOWLIST:-}"
    if [[ "$skill_allowlist" == *"*"* || "$skill_allowlist" == *"?"* ]]; then
        doctor_error skill "AGENTMILL_SKILL_ALLOWLIST must name explicit host skill directories, not wildcards"
    elif doctor_list_has_entries "$skill_allowlist"; then
        doctor_ok skill "allowlist: $skill_allowlist"
    elif [[ "$profile_level" != "trusted" ]] && doctor_truthy "${AGENTMILL_FORWARD_HOST_EXTENSIONS:-}"; then
        doctor_warn skill "AGENTMILL_FORWARD_HOST_EXTENSIONS=true outside trusted but AGENTMILL_SKILL_ALLOWLIST is empty; host skills will not be copied"
    elif [[ "$profile_level" != "trusted" ]]; then
        doctor_ok skill "host skills are not copied by default"
    else
        doctor_ok skill "trusted profile may copy host skills"
    fi

    local workspace_mode="${AGENTMILL_WORKSPACE_MODE:-auto}" allow_direct=false
    doctor_truthy "${AGENTMILL_ALLOW_DIRECT_HOST_REPO:-false}" && allow_direct=true
    case "$workspace_mode" in
        auto|direct|readonly-clone|clone-ro|ro-clone|"") ;;
        *) doctor_error workspace "invalid AGENTMILL_WORKSPACE_MODE=$workspace_mode (expected direct or readonly-clone)" ;;
    esac
    if [[ "$profile_level" != "trusted" && "$workspace_mode" == "direct" && "$allow_direct" != "true" ]]; then
        doctor_error workspace "standard/untrusted direct writable host repo mode requires AGENTMILL_ALLOW_DIRECT_HOST_REPO=true"
    elif [[ "$profile_level" != "trusted" && ( "$workspace_mode" == "auto" || -z "$workspace_mode" ) ]]; then
        doctor_ok workspace "mill run/watch will auto-select readonly-clone for $profile_level"
    elif [[ "$workspace_mode" == "readonly-clone" || "$workspace_mode" == "clone-ro" || "$workspace_mode" == "ro-clone" ]]; then
        doctor_ok workspace "read-only clone mode selected"
    else
        doctor_ok workspace "workspace mode: ${workspace_mode:-auto}"
    fi

    if grep -q 'read_only:.*AGENTMILL_READ_ONLY_ROOTFS' "$MILL_DIR/docker-compose.yml" 2>/dev/null; then
        doctor_ok filesystem "containers use read-only root filesystem by default"
    else
        doctor_warn filesystem "could not verify read-only root filesystem in docker-compose.yml"
    fi
    if grep -q '/tmp:rw,nosuid,nodev' "$MILL_DIR/docker-compose.yml" 2>/dev/null \
        && grep -q '/home/agent:rw,nosuid,nodev' "$MILL_DIR/docker-compose.yml" 2>/dev/null \
        && grep -q '/workspace:rw,nosuid,nodev' "$MILL_DIR/docker-compose.yml" 2>/dev/null; then
        doctor_ok filesystem "runtime scratch paths are tmpfs"
    else
        doctor_warn filesystem "could not verify tmpfs scratch paths in docker-compose.yml"
    fi
    if grep -q 'bubblewrap' "$MILL_DIR/Dockerfile" 2>/dev/null; then
        doctor_ok filesystem "image installs bubblewrap for non-native write-root sandboxes"
    else
        doctor_warn filesystem "could not verify bubblewrap install in Dockerfile"
    fi
    if [[ "$profile_level" != "trusted" && -n "${AGENTMILL_WRITE_ROOTS:-}" && "${AGENTMILL_WRITE_ROOT_SANDBOX:-auto}" != "off" ]]; then
        case "$selected_client" in
            opencode|qwen|gemini)
                if grep -q 'bubblewrap' "$MILL_DIR/Dockerfile" 2>/dev/null; then
                    doctor_ok filesystem "AGENTMILL_WRITE_ROOTS will use bubblewrap for $selected_client"
                else
                    doctor_error filesystem "AGENTMILL_WRITE_ROOTS for $selected_client requires bubblewrap in the image"
                fi
                ;;
        esac
    fi

    local hook_dir="${AGENTMILL_HOOK_DIR:-$MILL_DIR/hooks}" host_hook_dir
    case "$hook_dir" in
        /hooks) host_hook_dir="$MILL_DIR/hooks" ;;
        /*)     host_hook_dir="$hook_dir" ;;
        *)      host_hook_dir="$MILL_DIR/$hook_dir" ;;
    esac
    if [[ -d "$host_hook_dir" ]]; then
        doctor_ok hooks "$hook_dir maps to $host_hook_dir"
        local hook found_bad_hook=false
        for hook in "$host_hook_dir"/*.sh; do
            [[ -e "$hook" ]] || continue
            if [[ ! -x "$hook" ]]; then
                doctor_error hooks "$(basename "$hook") exists but is not executable"
                found_bad_hook=true
            fi
        done
        [[ "$found_bad_hook" == true ]] || doctor_ok hooks "all discovered hook scripts are executable"
    else
        doctor_warn hooks "$hook_dir does not exist; optional hooks are disabled"
    fi

    if grep -q '\./hooks:/hooks:ro' "$MILL_DIR/docker-compose.yml" 2>/dev/null; then
        doctor_ok hooks "docker-compose mounts hooks read-only"
    else
        doctor_warn hooks "could not verify read-only /hooks mount in docker-compose.yml"
    fi

    if command -v claude >/dev/null 2>&1; then
        local claude_version
        claude_version="$(claude --version 2>/dev/null | head -1 || true)"
        doctor_ok claude "CLI available${claude_version:+ ($claude_version)}"
    else
        doctor_warn claude "claude CLI not found on host; it is expected inside the AgentMill image"
    fi

    printf 'Doctor summary: %d error(s), %d warning(s)\n' "$DOCTOR_ERRORS" "$DOCTOR_WARNINGS"
    [[ "$DOCTOR_ERRORS" -eq 0 ]]
}

cmd_clean() {
    local log_dir="$MILL_DIR/logs"
    [[ -d "$log_dir" ]] || { echo "Nothing to clean."; return 0; }
    rm -f "$log_dir"/status-*.json "$log_dir"/agent-*.log "$log_dir"/session_*.log "$log_dir"/results.tsv "$log_dir"/convergence.tsv "$log_dir"/usage.tsv "$log_dir"/events.jsonl "$log_dir"/events.jsonl.lock
    echo "Cleaned logs from $log_dir"
}

# --- Main ---
load_env

case "${1:-}" in
    run)    shift; cmd_run "$@" ;;
    exec)   shift; cmd_exec "$@" ;;
    watch)  shift; cmd_watch "$@" ;;
    multi)  shift; cmd_multi "$@" ;;
    shell)  shift; cmd_shell "$@" ;;
    profiles) shift; cmd_profiles "$@" ;;
    ps)     shift; cmd_ps "$@" ;;
    status) shift; cmd_status "$@" ;;
    watch-status) shift; cmd_watch_status "$@" ;;
    web)    shift; cmd_web "$@" ;;
    logs)   shift; cmd_logs "$@" ;;
    tail)   shift; cmd_tail "$@" ;;
    build)  shift; cmd_build "$@" ;;
    stop)   shift; cmd_stop "$@" ;;
    memory) shift; cmd_memory "$@" ;;
    report) shift; cmd_report "$@" ;;
    history) shift; cmd_history "$@" ;;
    cost)   shift; cmd_cost "$@" ;;
    events) shift; cmd_events "$@" ;;
    metrics) shift; cmd_metrics "$@" ;;
    mcp)    shift; cmd_mcp "$@" ;;
    version) shift; cmd_version "$@" ;;
    diff)   shift; cmd_diff "$@" ;;
    patches) shift; cmd_patches "$@" ;;
    apply)  shift; cmd_apply "$@" ;;
    doctor) shift; cmd_doctor "$@" ;;
    clean)  shift; cmd_clean "$@" ;;
    init)   shift; cmd_init "$@" ;;
    --version) shift; cmd_version "$@" ;;
    -h|--help|help) usage 0 ;;
    "") usage 0 ;;
    *)  echo "Unknown command: $1" >&2; usage 1 ;;
esac
