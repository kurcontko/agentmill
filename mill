            --session) session=true; shift ;;
            --tail|--lines) tail_n="$2"; shift 2 ;;
            -f|--follow) follow=true; shift ;;
            --no-follow) follow=false; shift ;;
            --agent) agent_id="$2"; shift 2 ;;
            *)
                if [[ "${1:0:1}" == "-" ]]; then
                    echo "Error: unknown tail option: $1" >&2
                    return 1
                fi
                agent_id="$1"
                shift
                ;;
        esac
    done

    if [[ "$json" == true ]]; then
        local events_log="$MILL_DIR/logs/events.jsonl"
        if [[ "$follow" != true && ! -f "$events_log" ]]; then
            echo "No events log found. Run some iterations first."
            return 0
        fi
        python3 - "$events_log" "$tail_n" "$follow" "$agent_id" <<'PY'
import json
import sys
import time
from pathlib import Path

path = Path(sys.argv[1])
tail_n = int(sys.argv[2] or "20")
follow = sys.argv[3].lower() == "true"
agent = sys.argv[4]

def emit(line: str) -> None:
    if not line:
        return
    if agent:
        try:
            event = json.loads(line)
        except json.JSONDecodeError:
            return
        if str(event.get("agent_id", "")) != agent:
            return
    print(line, flush=True)

position = 0
if path.exists():
    lines = path.read_text(encoding="utf-8").splitlines()
    for line in lines[-tail_n:]:
        emit(line)
    position = path.stat().st_size

if not follow:
    raise SystemExit(0)

while True:
    if path.exists():
        size = path.stat().st_size
        if size < position:
            position = 0
        with path.open("r", encoding="utf-8") as handle:
            handle.seek(position)
            while True:
                line = handle.readline()
                if not line:
                    break
                position = handle.tell()
                emit(line.rstrip("\n"))
    time.sleep(0.25)
PY
        return 0
    fi

    agent_id="${agent_id:-1}"
    if [[ "$session" == true ]]; then
        cmd_logs --session "$agent_id"
    else
        cmd_logs "$agent_id"
    fi
}

