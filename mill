import csv
import glob
import json
import sys
from collections import defaultdict
from pathlib import Path

log_dir = Path(sys.argv[1])
output = Path(sys.argv[2])

def q(value: str) -> str:
    return value.replace("\\", "\\\\").replace('"', '\\"').replace("\n", "\\n")

def as_int(value):
    try:
        return int(float(value or 0))
    except ValueError:
        return 0

def as_float(value):
    try:
        return float(value or 0)
    except ValueError:
        return 0.0

lines = [
    "# HELP agentmill_results_iterations_total Iteration result rows by agent and status.",
    "# TYPE agentmill_results_iterations_total counter",
]

result_counts = defaultdict(int)
results_log = log_dir / "results.tsv"
if results_log.exists():
    for row in csv.DictReader(results_log.open(newline="", encoding="utf-8"), delimiter="\t"):
        result_counts[(row.get("agent", ""), row.get("status", ""))] += 1
for (agent, status), count in sorted(result_counts.items()):
    lines.append(f'agentmill_results_iterations_total{{agent="{q(agent)}",status="{q(status)}"}} {count}')

lines.extend([
    "# HELP agentmill_usage_total_tokens Total parsed token usage by agent.",
    "# TYPE agentmill_usage_total_tokens counter",
    "# HELP agentmill_usage_cost_usd Total estimated parsed cost by agent.",
    "# TYPE agentmill_usage_cost_usd counter",
    "# HELP agentmill_cache_read_ratio Cache-read token ratio by agent.",
    "# TYPE agentmill_cache_read_ratio gauge",
])
usage = defaultdict(lambda: {"total": 0, "cost": 0.0, "input": 0, "cache_creation": 0, "cache_read": 0})
usage_log = log_dir / "usage.tsv"
if usage_log.exists():
    for row in csv.DictReader(usage_log.open(newline="", encoding="utf-8"), delimiter="\t"):
