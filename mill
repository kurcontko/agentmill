    python3 - "$repo" "$json" <<'PY'
import csv
import json
import re
import sys
from pathlib import Path

repo = Path(sys.argv[1])
emit_json = sys.argv[2].lower() == "true"
report = repo / "REPORT.md"
memory = repo / "memory"
logs = repo / "logs"
sources = memory / "sources.md"
open_questions = memory / "open_questions.md"
results = logs / "results.tsv"

footnote_pattern = re.compile(r"\[\^[^\]]+\]")
url_pattern = re.compile(r"https?://[^\s)<>\"]+")

def read(path: Path) -> str:
    try:
        return path.read_text(encoding="utf-8")
    except OSError:
        return ""

def sections_from_report(text: str) -> list[dict[str, object]]:
    sections: list[dict[str, object]] = []
    current = None
    body: list[str] = []
    def section_stats(lines: list[str]) -> tuple[int, int]:
        content_lines = [
            line for line in lines
            if not re.match(r"^\[\^[^\]]+\]:", line.strip())
        ]
        joined = "\n".join(content_lines)
        return (
            len(footnote_pattern.findall(joined)),
            len(re.findall(r"\b\w+\b", joined)),
        )

    for line in text.splitlines():
        match = re.match(r"^(#{1,6})\s+(.+?)\s*$", line)
        if match:
            if current is not None:
                citations, words = section_stats(body)
                sections.append({
                    "level": current[0],
                    "title": current[1],
                    "citations": citations,
                    "words": words,
                })
            current = (len(match.group(1)), match.group(2))
            body = []
        elif current is not None:
            body.append(line)
    if current is not None:
        citations, words = section_stats(body)
        sections.append({
            "level": current[0],
            "title": current[1],
            "citations": citations,
            "words": words,
        })
    return sections

def unique_urls(text: str) -> list[str]:
    seen: set[str] = set()
    result: list[str] = []
    for raw in url_pattern.findall(text):
        url = raw.rstrip(".,;:")
        if url not in seen:
            seen.add(url)
            result.append(url)
    return result

def count_open_questions(text: str) -> int:
    count = 0
    in_header = False
    if text.startswith("---\n"):
        in_header = True
    for line in text.splitlines():
        if in_header:
            if line == "---":
                in_header = False
            continue
        stripped = line.strip()
        if not stripped or stripped.startswith("#") or stripped == "---":
            continue
        if stripped.startswith(("- [ ]", "- [x]", "- [X]")):
            if stripped.startswith("- [ ]"):
                count += 1
            continue
        if stripped.startswith("-"):
            count += 1
    return count

def recent_iterations(path: Path) -> list[dict[str, object]]:
    if not path.exists():
        return []
    rows = list(csv.DictReader(path.open(newline="", encoding="utf-8"), delimiter="\t"))
    out: list[dict[str, object]] = []
    for row in rows[-10:]:
        item = {
            "iteration": row.get("iteration", ""),
            "agent": row.get("agent", ""),
            "timestamp": row.get("timestamp", ""),
            "status": row.get("status", ""),
            "description": row.get("description", ""),
        }
        if "sources_added" in row:
            item["sources_added"] = row.get("sources_added", "")
        if "section" in row:
            item["section"] = row.get("section", "")
        out.append(item)
    return out

report_text = read(report)
source_text = read(sources)
open_question_text = read(open_questions)
sections = sections_from_report(report_text)
urls = unique_urls(source_text)
iterations = recent_iterations(results)
payload = {
    "repo": str(repo),
    "report_exists": report.exists(),
    "source_count": len(urls),
    "open_questions": count_open_questions(open_question_text),
    "sections": sections,
    "recent_iterations": iterations,
}

if emit_json:
    print(json.dumps(payload, sort_keys=True))
else:
    print(f"repo: {payload['repo']}")
    print(f"report_exists: {str(payload['report_exists']).lower()}")
    print(f"source_count: {payload['source_count']}")
    print(f"open_questions: {payload['open_questions']}")
    print("")
    print("sections:")
    for section in sections:
        indent = "  " * max(int(section["level"]) - 1, 0)
        print(f"  {indent}{section['title']}\tcitations={section['citations']}\twords={section['words']}")
    print("")
    print("recent_iterations:")
    for row in iterations:
        details = [f"iter={row['iteration']}", f"agent={row['agent']}", f"status={row['status']}"]
        if "sources_added" in row:
            details.append(f"sources_added={row['sources_added']}")
        if "section" in row:
            details.append(f"section={row['section']}")
        if row.get("description"):
            details.append(f"description={row['description']}")
        print("  " + "\t".join(details))
PY
}

