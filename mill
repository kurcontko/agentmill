cmd_memory() {
    local memory_dir="$MILL_DIR/memory" topic="" search="" clear=false action=""
    [[ -n "${REPO_PATH:-}" && -d "$REPO_PATH/memory" ]] && memory_dir="$REPO_PATH/memory"
    [[ -d "$memory_dir" ]] || { echo "No memory directory found."; exit 0; }

    if [[ "${1:-}" == "rotate" || "${1:-}" == "dedup" ]]; then
        action="$1"
        shift
    fi

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --search) search="$2"; shift 2 ;;
            --clear)  clear=true; shift ;;
            *) topic="${topic:-$1}"; shift ;;
        esac
    done

    if [[ "$action" == "rotate" ]]; then
        local stamp archive moved=false f
        stamp="$(date -u '+%Y%m%dT%H%M%SZ')"
        archive="$memory_dir/archive/$stamp"
        mkdir -p "$archive"
        for f in "$memory_dir"/*.md; do
            [[ -f "$f" ]] || continue
            mv "$f" "$archive/"
            moved=true
        done
        if [[ "$moved" == true ]]; then
            echo "Archived memory topics to $archive"
        else
            rmdir "$archive" 2>/dev/null || true
            echo "No memory topics to rotate."
        fi
    elif [[ "$action" == "dedup" ]]; then
        topic="${topic:-sources}"
        local file="$memory_dir/${topic}.md"
        [[ -f "$file" ]] || { echo "No memory for: $topic"; return 0; }
        python3 - "$file" <<'PY'
import re
import sys
from pathlib import Path

path = Path(sys.argv[1])
url_pattern = re.compile(r"https?://[^\s)<>\"]+")
lines = path.read_text(encoding="utf-8").splitlines(keepends=True)
seen: set[str] = set()
kept: list[str] = []
removed = 0
for line in lines:
    urls = url_pattern.findall(line)
    if urls and all(url in seen for url in urls):
        removed += 1
        continue
    kept.append(line)
    seen.update(urls)
path.write_text("".join(kept), encoding="utf-8")
print(f"Removed {removed} duplicate URL line(s) from {path.name}")
PY
    elif [[ "$clear" == true && -n "$topic" ]]; then
        rm -f "$memory_dir/${topic}.md" "$memory_dir/.${topic}.lock"
        echo "Cleared memory: $topic"
    elif [[ -n "$search" ]]; then
        grep -rn "$search" "$memory_dir"/*.md 2>/dev/null || echo "No matches."
    elif [[ -n "$topic" ]]; then
        [[ -f "$memory_dir/${topic}.md" ]] && cat "$memory_dir/${topic}.md" || echo "No memory for: $topic"
