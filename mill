patch_artifact_dir() {
    local artifact="$1"
    if [[ "$artifact" == /* && -d "$artifact" ]]; then
        printf '%s\n' "$artifact"
    elif [[ -d "$artifact" ]]; then
        (cd "$artifact" && pwd)
    elif [[ -d "$MILL_DIR/logs/patches/$artifact" ]]; then
        printf '%s/logs/patches/%s\n' "$MILL_DIR" "$artifact"
    else
        echo "Error: patch artifact not found: $artifact" >&2
        return 1
    fi
}

patch_metadata_value() {
    local artifact="$1" key="$2"
    awk -F= -v key="$key" '$1 == key {sub(/^[^=]*=/, ""); print; exit}' "$artifact/metadata.txt" 2>/dev/null || true
}

patch_files_for_artifact() {
    local artifact="$1"
    find "$artifact" -maxdepth 1 -type f -name '[0-9][0-9][0-9][0-9]-*.patch' -print 2>/dev/null | sort
}

cmd_patches() {
    local root="$MILL_DIR/logs/patches" latest=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --latest) latest=true; shift ;;
            *) shift ;;
        esac
    done
    [[ -d "$root" ]] || { echo "No patch artifacts found."; return 0; }

    if [[ "$latest" == true ]]; then
        local latest_dir
        latest_dir="$(find "$root" -mindepth 1 -maxdepth 1 -type d -print 2>/dev/null | sort | tail -1)"
        [[ -n "$latest_dir" ]] || { echo "No patch artifacts found."; return 0; }
        printf '%s\n' "$latest_dir"
        return 0
    fi

    printf "%-38s  %-12s  %-12s  %s\n" "ARTIFACT" "BRANCH" "HEAD" "PATH"
    local artifact branch head name
    for artifact in "$root"/*; do
        [[ -d "$artifact" ]] || continue
        name="$(basename "$artifact")"
        branch="$(patch_metadata_value "$artifact" branch)"
        head="$(patch_metadata_value "$artifact" head)"
        printf "%-38s  %-12s  %-12s  %s\n" "$name" "${branch:-?}" "${head:-?}" "$artifact"
    done
}

apply_patch_artifact_to_repo() {
    local artifact="$1" repo="$2" base patch uncommitted untracked
    base="$(patch_metadata_value "$artifact" base)"
    if [[ -n "$base" ]]; then
        git -C "$repo" cat-file -e "${base}^{commit}" 2>/dev/null || {
            echo "Error: artifact base commit is not present in target repo: $base" >&2
            return 1
        }
        if ! git -C "$repo" merge-base --is-ancestor "$base" HEAD 2>/dev/null; then
            echo "Warning: artifact base $base is not an ancestor of target HEAD; applying with git am --3way." >&2
        fi
    fi

    local patches=()
    while IFS= read -r patch; do patches+=("$patch"); done < <(patch_files_for_artifact "$artifact")
    uncommitted="$artifact/uncommitted.patch"
    untracked="$artifact/untracked-files.tgz"

    if [[ "${#patches[@]}" -eq 0 && ! -s "$uncommitted" && ! -s "$untracked" ]]; then
        echo "Error: artifact has no patches or untracked file archive: $artifact" >&2
        return 1
    fi

    if [[ "${#patches[@]}" -gt 0 ]]; then
        if ! git -C "$repo" am --3way "${patches[@]}"; then
            git -C "$repo" am --abort >/dev/null 2>&1 || true
            return 1
        fi
    fi
    if [[ -s "$uncommitted" ]]; then
        git -C "$repo" apply "$uncommitted"
    fi
    if [[ -s "$untracked" ]]; then
        tar -C "$repo" -xzf "$untracked"
        echo "Restored untracked files from artifact; review and commit them if desired."
    fi
}

cmd_apply() {
    local artifact="" repo="" branch="" check=false allow_dirty=false
    [[ $# -gt 0 && "${1:0:1}" != "-" ]] && { artifact="$1"; shift; }
    [[ $# -gt 0 && "${1:0:1}" != "-" ]] && { repo="$1"; shift; }
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --repo) repo="$2"; shift 2 ;;
            --branch) branch="$2"; shift 2 ;;
            --check) check=true; shift ;;
            --allow-dirty) allow_dirty=true; shift ;;
            *) echo "Error: unknown apply option: $1" >&2; return 1 ;;
        esac
    done
    [[ -n "$artifact" ]] || { echo "Error: patch artifact required" >&2; usage 1; }
    artifact="$(patch_artifact_dir "$artifact")"
    [[ -f "$artifact/metadata.txt" ]] || { echo "Error: missing artifact metadata: $artifact/metadata.txt" >&2; return 1; }

    repo="${repo:-${REPO_PATH:-}}"
    [[ -n "$repo" ]] || { echo "Error: repo path required (pass repo or set REPO_PATH)" >&2; return 1; }
    [[ "$repo" == /* ]] || repo="$PWD/$repo"
    [[ -d "$repo/.git" ]] || [[ -f "$repo/.git" ]] || { echo "Error: $repo is not a git repo" >&2; return 1; }

    if [[ "$allow_dirty" != true && -n "$(git -C "$repo" status --porcelain 2>/dev/null)" ]]; then
        echo "Error: target repo has uncommitted changes; commit/stash them or pass --allow-dirty" >&2
        return 1
    fi

    if [[ "$check" == true ]]; then
        local tmp worktree
        tmp="$(mktemp -d)"
        worktree="$tmp/worktree"
        git -C "$repo" worktree add --detach "$worktree" HEAD >/dev/null 2>&1
        if apply_patch_artifact_to_repo "$artifact" "$worktree"; then
            git -C "$repo" worktree remove --force "$worktree" >/dev/null 2>&1 || true
            rm -rf "$tmp"
            echo "Patch artifact applies cleanly: $artifact"
            return 0
        fi
        git -C "$repo" worktree remove --force "$worktree" >/dev/null 2>&1 || true
        rm -rf "$tmp"
        return 1
    fi

    if [[ -n "$branch" ]]; then
        if git -C "$repo" show-ref --verify --quiet "refs/heads/$branch"; then
            echo "Error: branch already exists: $branch" >&2
            return 1
        fi
        git -C "$repo" checkout -b "$branch" >/dev/null 2>&1
    fi

    apply_patch_artifact_to_repo "$artifact" "$repo"
}

