cmd_mcp() {
    local sub="${1:-list}" manifest="" json=false name="" require_reachable=false
    [[ $# -gt 0 ]] && shift
    case "$sub" in
        list)
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --json) json=true; shift ;;
                    --manifest) manifest="$2"; shift 2 ;;
                    *) echo "Error: unknown mcp list option: $1" >&2; return 1 ;;
                esac
            done
            ;;
        test)
            [[ $# -gt 0 && "${1:0:1}" != "-" ]] || { echo "Error: mcp test requires a server name" >&2; return 1; }
            name="$1"; shift
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --manifest) manifest="$2"; shift 2 ;;
                    --require-reachable|--reachable) require_reachable=true; shift ;;
                    *) echo "Error: unknown mcp test option: $1" >&2; return 1 ;;
                esac
            done
            ;;
        -h|--help|help)
            usage 0
            ;;
        *)
            echo "Error: unknown mcp subcommand: $sub" >&2
            return 1
            ;;
    esac

    manifest="${manifest:-$(mcp_latest_manifest)}"
    [[ -n "$manifest" && -f "$manifest" ]] || { echo "No MCP manifest found. Run an agent once or pass --manifest."; return 1; }

    python3 - "$sub" "$manifest" "$json" "$name" "$require_reachable" <<'PY'
import json
import os
import shutil
import sys
from pathlib import Path

sub, manifest_path, json_output, name, require_reachable = sys.argv[1:6]
manifest = json.loads(Path(manifest_path).read_text())
servers = manifest.get("servers", [])

def reachability(server: dict) -> tuple[bool, str]:
    transport = str(server.get("transport", "unknown"))
    if transport == "stdio":
        command = str(server.get("command", "")).strip()
        if not command:
            return False, "stdio command metadata is missing"
        if command.startswith("/"):
            return (os.access(command, os.X_OK), f"stdio command: {command}")
        return (shutil.which(command) is not None, f"stdio command: {command}")
    if transport in {"remote", "http", "sse", "streamable-http"} or server.get("url_host"):
        scheme = str(server.get("url_scheme", "")).strip()
        host = str(server.get("url_host", "")).strip()
        if scheme and host:
            return True, f"remote endpoint: {scheme}://{host}"
        return False, "remote endpoint metadata is incomplete"
    return False, f"unsupported transport metadata: {transport}"

if sub == "list":
    if json_output == "true":
        print(json.dumps(manifest, sort_keys=True))
    else:
        print(f"manifest: {manifest_path}")
        print(f"run_id: {manifest.get('run_id', '')}")
        print(f"profile: {manifest.get('profile', '')}")
        print(f"mcp_allowlist: {','.join(manifest.get('mcp_allowlist', []))}")
        if not servers:
            print("servers: none")
        else:
            for server in servers:
                print(f"{server.get('name', '')}\t{server.get('source', '')}\t{server.get('config_hash', '')}")
    raise SystemExit(0)

matches = [server for server in servers if server.get("name") == name]
if not matches:
    print(f"MCP server not found in manifest: {name}", file=sys.stderr)
    raise SystemExit(1)

allowlist = manifest.get("mcp_allowlist", [])
allowed = not allowlist or name in allowlist
if not allowed:
    print(f"MCP server present but not in manifest allowlist: {name}", file=sys.stderr)
    raise SystemExit(1)

if require_reachable == "true":
    results = [reachability(server) for server in matches]
    if not any(ok for ok, _detail in results):
        print(f"MCP server present but not reachable from manifest metadata: {name}", file=sys.stderr)
        for _ok, detail in results:
            print(f"- {detail}", file=sys.stderr)
        raise SystemExit(1)
    detail = next(detail for ok, detail in results if ok)
    print(f"OK {name}: {len(matches)} manifest entr{'y' if len(matches) == 1 else 'ies'}; {detail}")
else:
    print(f"OK {name}: {len(matches)} manifest entr{'y' if len(matches) == 1 else 'ies'}")
PY
}

