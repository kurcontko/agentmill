#!/usr/bin/env bash
set -euo pipefail

MILL_SOURCE="${BASH_SOURCE[0]}"
while [ -L "$MILL_SOURCE" ]; do
    MILL_DIR="$(cd -P "$(dirname "$MILL_SOURCE")" && pwd)"
    MILL_SOURCE="$(readlink "$MILL_SOURCE")"
    [[ $MILL_SOURCE != /* ]] && MILL_SOURCE="$MILL_DIR/$MILL_SOURCE"
done
MILL_DIR="$(cd -P "$(dirname "$MILL_SOURCE")" && pwd)"

usage() {
    cat <<'EOF'
mill — AgentMill CLI

Usage:
  mill run   <repo> [--agent ROLE] [--workspace-mode direct|readonly-clone] [--model M] [--iterations N] [--max-log-bytes B] [--max-total-tokens N] [--max-total-usd USD] [--prompt FILE] [--delay S] [--auto-commit MODE] [--json] [-d]
  mill exec  <repo> [--agent ROLE] [--workspace-mode direct|readonly-clone] [--model M] [--max-log-bytes B] [--max-total-tokens N] [--max-total-usd USD] [--prompt FILE] [--auto-commit MODE]
  mill watch <repo> [--agent ROLE] [--transport native|acp] [--workspace-mode direct|readonly-clone] [--model M] [--max-log-bytes B] [--max-total-tokens N] [--max-total-usd USD] [--prompt FILE] [--ralph] [--respawn]
  mill multi <repo> [N] [-d] [--roles A,B,C] [--model M] [--iterations N] [--max-log-bytes B] [--max-total-tokens N] [--max-total-usd USD]
  mill shell <repo> [--transport native|acp] [--prompt TEXT]  Interactive client session
  mill profiles [ROLE]              List profiles or show ROLE env exports
  mill ps                           Show running containers
  mill status [--json]              Show agent iteration status
  mill watch-status [--once] [--interval S]  Live dashboard from status/history logs
  mill web [--port P] [--no-serve]  Generate logs/index.html and optionally serve logs/
  mill logs   [agent-id] [--session]  Tail agent or session logs
  mill tail   [agent-id] [--json] [--tail N] [--no-follow]  Tail logs or JSON events
  mill build  [--platform PLAT] [--pull]  Build the container image, or pull the published image first
  mill stop [--on-converge] [--timeout S] [--agent ID] [--run-id ID]  Stop services now, or after convergence
  mill memory  [topic] [--search Q] [--clear]  View, search, clear, dedup, or rotate memory
  mill report status [repo] [--json]  Summarize research report/source audit state
  mill history [--tail N] [--json] [--since TS] [--agent N] [--failed-only]  Show iteration results log
  mill cost    [--json] [--by agent|day|week|iteration]  Summarize usage and cost telemetry
  mill events  [--tail N] [--follow]  Show structured event log
  mill metrics                      Write Prometheus textfile metrics to logs/metrics.prom
  mill mcp list [--json] [--manifest FILE]  List MCP servers from a manifest snapshot
  mill mcp test <name> [--manifest FILE] [--require-reachable]  Check that an MCP server is present
  mill version [--json]            Print harness, image, host, and model defaults
  mill diff    [N]                  Show last N commits + uncommitted changes
  mill patches [--latest]           List read-only clone patch artifacts
  mill apply <artifact> [repo] [--branch BR] [--check]  Apply a patch artifact
  mill doctor [repo] [--profile-level L] [--fix]  Validate harness configuration
  mill clean                        Remove log and status files
  mill init [--research TOPIC] [--dir DIR]  Create .env, starter prompt, or research repo scaffold

Environment:
  ANTHROPIC_API_KEY or CLAUDE_CODE_OAUTH_TOKEN must be set (or in .env).

Examples:
  mill run ~/projects/myapp
  mill exec ~/projects/myapp --agent reviewer
  mill run ~/projects/myapp --model opus --iterations 5 -d
  mill watch ~/projects/myapp --ralph
  mill multi ~/projects/myapp 2
  mill status
EOF
    exit "${1:-0}"
}

# Parse .env file if it exists (handles KEY=value, KEY="value", KEY='value')
load_env() {
    [[ -f "$MILL_DIR/.env" ]] || return 0
    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line%%\#*}"                         # strip comments
        [[ "$line" =~ ^[[:space:]]*$ ]] && continue # skip blank lines
        [[ "$line" =~ ^([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]] || continue
        local key="${BASH_REMATCH[1]}" val="${BASH_REMATCH[2]}"
        val="${val#\"}" val="${val%\"}"              # strip double quotes
        val="${val#\'}" val="${val%\'}"              # strip single quotes
        val="${val%"${val##*[! ]}"}"                 # trim trailing spaces
        if [[ -z "${!key:-}" ]]; then
            export "$key=$val"
        fi
    done < "$MILL_DIR/.env"
    return 0
}

compose() {
    local override="" rc
    override="$(compose_network_policy_override "$@")"
    if docker compose version >/dev/null 2>&1; then
        if [[ -n "$override" ]]; then
            docker compose -f "$MILL_DIR/docker-compose.yml" -f "$override" "$@"
            rc=$?
        else
            docker compose -f "$MILL_DIR/docker-compose.yml" "$@"
            rc=$?
        fi
    else
        if [[ -n "$override" ]]; then
            docker-compose -f "$MILL_DIR/docker-compose.yml" -f "$override" "$@"
            rc=$?
        else
            docker-compose -f "$MILL_DIR/docker-compose.yml" "$@"
            rc=$?
        fi
    fi
    [[ -n "$override" ]] && rm -f "$override"
    return "$rc"
}

compose_known_service() {
    case "${1:-}" in
        headless|headless-clone|watch|watch-clone|interactive|agent-1|agent-2|agent-3) return 0 ;;
        *) return 1 ;;
    esac
}

compose_service_network() {
    local service="$1"
    case "$service" in
        agent-1) printf '%s\n' "${AGENTMILL_NETWORK_1:-${AGENTMILL_NETWORK:-}}" ;;
        agent-2) printf '%s\n' "${AGENTMILL_NETWORK_2:-${AGENTMILL_NETWORK:-}}" ;;
        agent-3) printf '%s\n' "${AGENTMILL_NETWORK_3:-${AGENTMILL_NETWORK:-}}" ;;
        *)       printf '%s\n' "${AGENTMILL_NETWORK:-}" ;;
    esac
}

compose_network_policy_override() {
    local arg service network tmp="" needs_override=false needs_proxy=false action="${1:-}" enforce_allowlist=false
    local -a services=()
    case "$action" in
        up|run|create|start|restart) enforce_allowlist=true ;;
    esac
    for arg in "$@"; do
        if compose_known_service "$arg"; then
            services+=("$arg")
        fi
    done
    if [[ "${#services[@]}" -eq 0 ]]; then
        services=(headless headless-clone watch watch-clone interactive agent-1 agent-2 agent-3)
    fi
    for service in "${services[@]}"; do
        network="$(compose_service_network "$service")"
        case "$network" in
            deny) needs_override=true ;;
            allowlist)
                if [[ "$enforce_allowlist" == true && -z "${AGENTMILL_EGRESS_ALLOWLIST:-}" ]]; then
                    echo "Error: AGENTMILL_NETWORK=allowlist requires AGENTMILL_EGRESS_ALLOWLIST" >&2
                    exit 1
                fi
                needs_override=true
                needs_proxy=true
                ;;
        esac
    done
    if [[ "$needs_override" == true ]]; then
        tmp="$(mktemp "${TMPDIR:-/tmp}/agentmill-network-policy.XXXXXX.yml")"
        printf 'services:\n' > "$tmp"
        if [[ "$needs_proxy" == true ]]; then
            cat >> "$tmp" <<'YAML'
  agentmill-egress-proxy:
    image: ${AGENTMILL_IMAGE:-agentmill:latest}
    build: .
    entrypoint: ["/agentmill-egress-proxy.py"]
    restart: unless-stopped
    security_opt: [no-new-privileges:true]
    cap_drop: [ALL]
    read_only: true
    pids_limit: 128
    mem_limit: 256m
    tmpfs:
      - /tmp:rw,nosuid,nodev,mode=1777
    environment:
      AGENTMILL_EGRESS_ALLOWLIST: ${AGENTMILL_EGRESS_ALLOWLIST:-}
      AGENTMILL_EGRESS_PROXY_PORT: ${AGENTMILL_EGRESS_PROXY_PORT:-18080}
    networks:
      - agentmill-egress-public
      - agentmill-egress-internal
YAML
        fi
        for service in "${services[@]}"; do
            network="$(compose_service_network "$service")"
            case "$network" in
                deny)
                    printf '  %s:\n    network_mode: "none"\n    networks: []\n' "$service" >> "$tmp"
                    ;;
                allowlist)
                    printf '  %s:\n' "$service" >> "$tmp"
                    cat >> "$tmp" <<'YAML'
    depends_on:
      - agentmill-egress-proxy
    networks:
      - agentmill-egress-internal
    environment:
      HTTP_PROXY: "http://agentmill-egress-proxy:${AGENTMILL_EGRESS_PROXY_PORT:-18080}"
      HTTPS_PROXY: "http://agentmill-egress-proxy:${AGENTMILL_EGRESS_PROXY_PORT:-18080}"
      ALL_PROXY: "http://agentmill-egress-proxy:${AGENTMILL_EGRESS_PROXY_PORT:-18080}"
      http_proxy: "http://agentmill-egress-proxy:${AGENTMILL_EGRESS_PROXY_PORT:-18080}"
      https_proxy: "http://agentmill-egress-proxy:${AGENTMILL_EGRESS_PROXY_PORT:-18080}"
      all_proxy: "http://agentmill-egress-proxy:${AGENTMILL_EGRESS_PROXY_PORT:-18080}"
      NO_PROXY: localhost,127.0.0.1,::1,agentmill-egress-proxy
      no_proxy: localhost,127.0.0.1,::1,agentmill-egress-proxy
YAML
                    ;;
            esac
        done
        if [[ "$needs_proxy" == true ]]; then
            cat >> "$tmp" <<'YAML'
networks:
  agentmill-egress-internal:
    internal: true
  agentmill-egress-public: {}
YAML
        fi
        printf '%s\n' "$tmp"
    fi
    return 0
}

stream_events_for_run() {
    local events_log="$1" run_id="$2" stop_file="$3" start_position="${4:-0}"
    python3 - "$events_log" "$run_id" "$stop_file" "$start_position" <<'PY'
import json
import time
import sys
from pathlib import Path

path = Path(sys.argv[1])
run_id = sys.argv[2]
stop = Path(sys.argv[3])
try:
    position = int(sys.argv[4])
except ValueError:
    position = 0

while True:
    if path.exists():
        try:
            size = path.stat().st_size
            if size < position:
                position = 0
            with path.open("r", encoding="utf-8") as handle:
                handle.seek(position)
                while True:
                    line = handle.readline()
                    if not line:
                        break
                    position = handle.tell()
                    try:
                        event = json.loads(line)
                    except json.JSONDecodeError:
                        continue
                    if event.get("run_id") == run_id:
                        print(json.dumps(event, sort_keys=True), flush=True)
        except OSError:
            pass
    if stop.exists():
        break
    time.sleep(0.1)
PY
}

emit_mill_run_completed() {
    local exit_code="$1" command="$2"
    python3 - "$AGENTMILL_RUN_ID" "${AGENTMILL_PROFILE_LEVEL:-trusted}" "$exit_code" "$command" <<'PY'
import json
import sys
from datetime import datetime, timezone

run_id, profile, exit_code, command = sys.argv[1], sys.argv[2], int(sys.argv[3]), sys.argv[4]
event = {
    "version": 1,
    "timestamp": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    "run_id": run_id,
    "agent_id": "cli",
    "profile": profile,
    "iteration": 0,
    "type": "mill.run.completed",
    "payload": {
        "exit_code": exit_code,
        "command": command,
        "status": "ok" if exit_code == 0 else "error",
    },
}
print(json.dumps(event, sort_keys=True), flush=True)
PY
}

compose_json_run() {
    local events_log="$MILL_DIR/logs/events.jsonl" stop_file stream_pid rc command start_position=0
    mkdir -p "$MILL_DIR/logs"
    if [[ -z "${AGENTMILL_RUN_ID:-}" ]]; then
        export AGENTMILL_RUN_ID="mill-$(date -u '+%Y%m%dT%H%M%SZ')-$$"
    fi
    command="$*"
    if [[ -f "$events_log" ]]; then
        start_position="$(wc -c < "$events_log" | tr -d ' ')"
    fi
    stop_file="$(mktemp)"
    rm -f "$stop_file"
    stream_events_for_run "$events_log" "$AGENTMILL_RUN_ID" "$stop_file" "$start_position" &
    stream_pid=$!

    set +e
    compose "$@" >&2
    rc=$?
    set -e

    touch "$stop_file"
    wait "$stream_pid" || true
    rm -f "$stop_file"
    emit_mill_run_completed "$rc" "$command"
    return "$rc"
}

require_repo() {
    [[ -n "${1:-}" ]] || { echo "Error: repo path required" >&2; usage 1; }
    local repo="$1"
    [[ "$repo" == /* ]] || repo="$PWD/$repo"
    [[ -d "$repo/.git" ]] || [[ -f "$repo/.git" ]] || { echo "Error: $repo is not a git repo" >&2; exit 1; }
    export REPO_PATH="$repo"
}

profile_file() {
    local role="$1" file
    [[ "$role" =~ ^[A-Za-z0-9_-]+$ ]] || { echo "Error: invalid agent role '$role'" >&2; exit 1; }
    file="$MILL_DIR/agents/${role}.toml"
    [[ -f "$file" ]] || { echo "Error: unknown agent role '$role' (expected one of: $(list_profile_names | tr '\n' ' '))" >&2; exit 1; }
    printf '%s\n' "$file"
}

list_profile_names() {
    local f
    for f in "$MILL_DIR"/agents/*.toml; do
        [[ -f "$f" ]] || continue
        basename "$f" .toml
    done | sort
}

profile_exports() {
    local role="$1" agent_id="${2:-1}" suffix="${3:-}" mode="${4:-}" file
    local -a args=()
    file="$(profile_file "$role")"
    [[ "$mode" == "--defaults" ]] && args+=(--defaults)
    python3 "$MILL_DIR/scripts/profile-env.py" "$file" --role "$role" --agent-id "$agent_id" --suffix "$suffix" "${args[@]}"
}

apply_agent_profile() {
    local role="$1" agent_id="${2:-1}" suffix="${3:-}"
    eval "$(profile_exports "$role" "$agent_id" "$suffix" --defaults)"
}

profile_requires_clone() {
    local profile="${AGENTMILL_PROFILE_LEVEL:-trusted}"
    [[ "$profile" != "trusted" ]] && ! doctor_truthy "${AGENTMILL_ALLOW_DIRECT_HOST_REPO:-false}"
}

normalize_workspace_mode() {
    local mode="${1:-auto}"
    case "$mode" in
        auto|"")
            if profile_requires_clone; then
                printf '%s\n' "readonly-clone"
            else
                printf '%s\n' "direct"
            fi
            ;;
        direct)
            if profile_requires_clone; then
                echo "Error: standard/untrusted direct workspace mode requires AGENTMILL_ALLOW_DIRECT_HOST_REPO=true" >&2
                exit 1
            fi
            printf '%s\n' "direct"
            ;;
        readonly-clone|clone-ro|ro-clone) printf '%s\n' "readonly-clone" ;;
        *)
            echo "Error: invalid workspace mode '$mode' (expected direct or readonly-clone)" >&2
            exit 1
            ;;
    esac
}

cmd_run() {
    local repo="" agent="" model="" iterations="" prompt="" delay="" auto_commit="" max_wall="" max_log="" max_tokens="" max_usd="" output_format="" profile_level="" workspace_mode="" detach=false json=false
    [[ $# -gt 0 && "${1:0:1}" != "-" ]] && { repo="$1"; shift; }
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --agent)       agent="$2"; shift 2 ;;
            --model)       model="$2"; shift 2 ;;
            --iterations)  iterations="$2"; shift 2 ;;
            --prompt)      prompt="$2"; shift 2 ;;
            --delay)       delay="$2"; shift 2 ;;
            --auto-commit) auto_commit="$2"; shift 2 ;;
            --max-wall-seconds) max_wall="$2"; shift 2 ;;
            --max-log-bytes) max_log="$2"; shift 2 ;;
            --max-total-tokens) max_tokens="$2"; shift 2 ;;
            --max-total-usd) max_usd="$2"; shift 2 ;;
            --claude-output-format|--output-format) output_format="$2"; shift 2 ;;
            --profile-level) profile_level="$2"; shift 2 ;;
            --workspace-mode) workspace_mode="$2"; shift 2 ;;
            --json)        json=true; shift ;;
            -d|--detach)   detach=true; shift ;;
            *) repo="${repo:-$1}"; shift ;;
        esac
    done
    if [[ "$json" == true && "$detach" == true ]]; then
        echo "Error: mill run --json cannot be combined with --detach" >&2
        exit 1
    fi
    require_repo "$repo"
    [[ -n "$agent" ]]      && apply_agent_profile "$agent" 1
    [[ -n "$model" ]]       && export MODEL="$model"
    [[ -n "$iterations" ]]  && export MAX_ITERATIONS="$iterations"
    [[ -n "$prompt" ]]      && export PROMPT_FILE="$prompt"
    [[ -n "$delay" ]]       && export LOOP_DELAY="$delay"
    [[ -n "$auto_commit" ]] && export AUTO_COMMIT="$auto_commit"
    [[ -n "$max_wall" ]]    && export MAX_WALL_SECONDS="$max_wall"
    [[ -n "$max_log" ]]     && export MAX_LOG_BYTES="$max_log"
    [[ -n "$max_tokens" ]]  && export MAX_TOTAL_TOKENS="$max_tokens"
    [[ -n "$max_usd" ]]     && export MAX_TOTAL_USD="$max_usd"
    [[ -n "$output_format" ]] && export AGENTMILL_CLAUDE_OUTPUT_FORMAT="$output_format"
    [[ -n "$profile_level" ]] && export AGENTMILL_PROFILE_LEVEL="$profile_level"
    workspace_mode="$(normalize_workspace_mode "${workspace_mode:-${AGENTMILL_WORKSPACE_MODE:-auto}}")"
    export AGENTMILL_WORKSPACE_MODE="$workspace_mode"

    local up_args=(up)
    [[ "$detach" == true ]] && up_args+=(-d)
    if [[ "$workspace_mode" == "readonly-clone" ]]; then
        up_args+=(headless-clone)
    else
        up_args+=(headless)
    fi
    if [[ "$json" == true ]]; then
        compose_json_run "${up_args[@]}"
    else
        compose "${up_args[@]}"
    fi
}

cmd_exec() {
    local repo="" agent="" model="" prompt="" auto_commit="" max_wall="" max_log="" max_tokens="" max_usd="" output_format="" profile_level="" workspace_mode=""
    [[ $# -gt 0 && "${1:0:1}" != "-" ]] && { repo="$1"; shift; }
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --agent)       agent="$2"; shift 2 ;;
            --model)       model="$2"; shift 2 ;;
            --prompt)      prompt="$2"; shift 2 ;;
            --auto-commit) auto_commit="$2"; shift 2 ;;
            --max-wall-seconds) max_wall="$2"; shift 2 ;;
            --max-log-bytes) max_log="$2"; shift 2 ;;
            --max-total-tokens) max_tokens="$2"; shift 2 ;;
            --max-total-usd) max_usd="$2"; shift 2 ;;
            --claude-output-format|--output-format) output_format="$2"; shift 2 ;;
            --profile-level) profile_level="$2"; shift 2 ;;
            --workspace-mode) workspace_mode="$2"; shift 2 ;;
            --iterations)
                echo "Error: mill exec always runs exactly one iteration; use mill run for loops" >&2
                exit 1
                ;;
            *) repo="${repo:-$1}"; shift ;;
        esac
    done
    require_repo "$repo"
    [[ -n "$agent" ]]      && apply_agent_profile "$agent" 1
    [[ -n "$model" ]]       && export MODEL="$model"
    [[ -n "$prompt" ]]      && export PROMPT_FILE="$prompt"
    [[ -n "$auto_commit" ]] && export AUTO_COMMIT="$auto_commit"
    [[ -n "$max_wall" ]]    && export MAX_WALL_SECONDS="$max_wall"
    [[ -n "$max_log" ]]     && export MAX_LOG_BYTES="$max_log"
    [[ -n "$max_tokens" ]]  && export MAX_TOTAL_TOKENS="$max_tokens"
    [[ -n "$max_usd" ]]     && export MAX_TOTAL_USD="$max_usd"
    [[ -n "$output_format" ]] && export AGENTMILL_CLAUDE_OUTPUT_FORMAT="$output_format"
    [[ -n "$profile_level" ]] && export AGENTMILL_PROFILE_LEVEL="$profile_level"
    export MAX_ITERATIONS=1
    export LOOP_DELAY=0
    export AGENTMILL_RUN_MODE=exec
    workspace_mode="$(normalize_workspace_mode "${workspace_mode:-${AGENTMILL_WORKSPACE_MODE:-auto}}")"
    export AGENTMILL_WORKSPACE_MODE="$workspace_mode"

    if [[ "$workspace_mode" == "readonly-clone" ]]; then
        compose run --rm headless-clone
    else
        compose run --rm headless
    fi
}

cmd_watch() {
    local repo="" agent="" ralph=false respawn=false prompt="" model="" max_wall="" max_log="" max_tokens="" max_usd="" profile_level="" workspace_mode="" transport=""
    [[ $# -gt 0 && "${1:0:1}" != "-" ]] && { repo="$1"; shift; }
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --agent)   agent="$2"; shift 2 ;;
            --transport) transport="$2"; shift 2 ;;
            --acp)     transport=acp; shift ;;
            --ralph)   ralph=true; shift ;;
            --respawn) respawn=true; shift ;;
            --prompt)  prompt="$2"; shift 2 ;;
            --model)   model="$2"; shift 2 ;;
            --max-wall-seconds) max_wall="$2"; shift 2 ;;
            --max-log-bytes) max_log="$2"; shift 2 ;;
            --max-total-tokens) max_tokens="$2"; shift 2 ;;
            --max-total-usd) max_usd="$2"; shift 2 ;;
            --profile-level) profile_level="$2"; shift 2 ;;
            --workspace-mode) workspace_mode="$2"; shift 2 ;;
            *) repo="${repo:-$1}"; shift ;;
        esac
    done
    require_repo "$repo"
    [[ -n "$agent" ]]          && apply_agent_profile "$agent" 1
    [[ "$ralph" == true ]]   && export AUTO_RALPH=true
    [[ "$respawn" == true ]] && export RESPAWN=true
    [[ -n "$prompt" ]]       && export PROMPT_FILE="$prompt"
    [[ -n "$model" ]]        && export MODEL="$model"
    [[ -n "$max_wall" ]]     && export MAX_WALL_SECONDS="$max_wall"
    [[ -n "$max_log" ]]      && export MAX_LOG_BYTES="$max_log"
    [[ -n "$max_tokens" ]]   && export MAX_TOTAL_TOKENS="$max_tokens"
    [[ -n "$max_usd" ]]      && export MAX_TOTAL_USD="$max_usd"
    [[ -n "$profile_level" ]] && export AGENTMILL_PROFILE_LEVEL="$profile_level"
    [[ -n "$transport" ]] && export AGENTMILL_CLIENT_TRANSPORT="$transport"
    workspace_mode="$(normalize_workspace_mode "${workspace_mode:-${AGENTMILL_WORKSPACE_MODE:-auto}}")"
    export AGENTMILL_WORKSPACE_MODE="$workspace_mode"
    if [[ "$workspace_mode" == "readonly-clone" ]]; then
        compose run watch-clone
    else
        compose run watch
    fi
}

cmd_multi() {
    local repo="" count="" roles="" detach=false model="" iterations="" delay="" max_wall="" max_log="" max_tokens="" max_usd="" profile_level=""
    [[ $# -gt 0 && "${1:0:1}" != "-" ]] && { repo="$1"; shift; }
    [[ $# -gt 0 && "${1:0:1}" != "-" ]] && { count="$1"; shift; }
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -d|--detach)   detach=true; shift ;;
            --roles)       roles="$2"; shift 2 ;;
            --model)       model="$2"; shift 2 ;;
            --iterations)  iterations="$2"; shift 2 ;;
            --delay)       delay="$2"; shift 2 ;;
            --max-wall-seconds) max_wall="$2"; shift 2 ;;
            --max-log-bytes) max_log="$2"; shift 2 ;;
            --max-total-tokens) max_tokens="$2"; shift 2 ;;
            --max-total-usd) max_usd="$2"; shift 2 ;;
            --profile-level) profile_level="$2"; shift 2 ;;
            *) repo="${repo:-$1}"; shift ;;
        esac
    done
    require_repo "$repo"
    if [[ -n "$roles" ]]; then
        local role_list=()
        IFS=',' read -r -a role_list <<< "$roles"
        [[ -n "$count" ]] || count="${#role_list[@]}"
        [[ "$count" =~ ^[0-9]+$ ]] || { echo "Error: agent count must be numeric" >&2; exit 1; }
        [[ "$count" -eq "${#role_list[@]}" ]] || { echo "Error: --roles count (${#role_list[@]}) must match agent count ($count)" >&2; exit 1; }
        local i role
        for i in "${!role_list[@]}"; do
            role="${role_list[$i]}"
            role="${role#"${role%%[![:space:]]*}"}"
            role="${role%"${role##*[![:space:]]}"}"
            [[ -n "$role" ]] || { echo "Error: empty role in --roles" >&2; exit 1; }
            apply_agent_profile "$role" "$((i + 1))" "_$((i + 1))"
        done
    fi
    count="${count:-3}"
    [[ "$count" =~ ^[0-9]+$ ]] || { echo "Error: agent count must be numeric" >&2; exit 1; }
