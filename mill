        AUTO_COMMIT_1 AUTO_COMMIT_2 AUTO_COMMIT_3; do
        known_keys["$key"]=1
    done

    if [[ -f "$env_file" ]]; then
        doctor_ok env ".env exists"
        while IFS= read -r line || [[ -n "$line" ]]; do
            line="${line%%#*}"
            [[ "$line" =~ ^[[:space:]]*([A-Za-z_][A-Za-z0-9_]*)= ]] || continue
            key="${BASH_REMATCH[1]}"
            [[ -n "${known_keys[$key]:-}" ]] || unknown_keys+=("$key")
        done < "$env_file"
        if [[ "${#unknown_keys[@]}" -gt 0 ]]; then
            doctor_warn env "unknown .env keys: ${unknown_keys[*]}"
        else
            doctor_ok env ".env keys match known schema"
        fi
    else
        doctor_warn env ".env not found; set required env vars another way or run 'mill doctor --fix'"
    fi

    if [[ -z "${REPO_PATH:-}" ]]; then
