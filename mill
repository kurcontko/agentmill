            --agent) agent="$2"; shift 2 ;;
            --run-id) run_id="$2"; shift 2 ;;
            *) echo "Error: unknown stop option: $1" >&2; return 1 ;;
        esac
    done

    if [[ "$on_converge" == true ]]; then
        wait_for_convergence "$timeout" "$agent" "$run_id"
    fi
    compose down
}

