        usage[agent]["total"] += as_int(row.get("total_tokens"))
        usage[agent]["cost"] += as_float(row.get("cost_usd"))
        usage[agent]["input"] += as_int(row.get("input_tokens"))
        usage[agent]["cache_creation"] += as_int(row.get("cache_creation_input_tokens"))
        usage[agent]["cache_read"] += as_int(row.get("cache_read_input_tokens"))
for agent, item in sorted(usage.items()):
    denom = item["input"] + item["cache_creation"] + item["cache_read"]
    ratio = item["cache_read"] / denom if denom else 0.0
    lines.append(f'agentmill_usage_total_tokens{{agent="{q(agent)}"}} {item["total"]}')
    lines.append(f'agentmill_usage_cost_usd{{agent="{q(agent)}"}} {item["cost"]:.6f}')
    lines.append(f'agentmill_cache_read_ratio{{agent="{q(agent)}"}} {ratio:.6f}')

lines.extend([
    "# HELP agentmill_status_iteration Last reported iteration by agent and state.",
    "# TYPE agentmill_status_iteration gauge",
])
for status_path in sorted(glob.glob(str(log_dir / "status-*.json"))):
    try:
        data = json.loads(Path(status_path).read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        continue
    agent = str(data.get("agent", Path(status_path).stem.removeprefix("status-")))
    state = str(data.get("state", "unknown"))
    iteration = as_int(data.get("iteration"))
    lines.append(f'agentmill_status_iteration{{agent="{q(agent)}",state="{q(state)}"}} {iteration}')

output.write_text("\n".join(lines) + "\n", encoding="utf-8")
print(output)
PY
