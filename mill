        echo "Memory topics:"
        for f in "$memory_dir"/*.md; do
            [[ -f "$f" ]] || continue
            local name count
            name="$(basename "$f" .md)"
            count="$(grep -c '^---$' "$f" 2>/dev/null || echo 0)"
            if [[ "$(head -1 "$f" 2>/dev/null)" == "---" ]] && grep -q '^type: ' "$f" 2>/dev/null && [[ "$count" -ge 2 ]]; then
                count=$(( count - 2 ))
            fi
            printf '  [[%s]] (%d entries)\n' "$name" "$(( count / 2 ))"
        done
    fi
}

