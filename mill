wait_for_convergence() {
    local timeout="${1:-0}" agent="${2:-}" run_id="${3:-}"
    python3 - "$MILL_DIR/logs/events.jsonl" "$MILL_DIR/logs/convergence.tsv" "$timeout" "$agent" "$run_id" <<'PY'
import csv
import json
import sys
import time
from pathlib import Path

events_path = Path(sys.argv[1])
convergence_path = Path(sys.argv[2])
try:
    timeout = float(sys.argv[3] or "0")
except ValueError:
    print("Error: --timeout must be a non-negative number", file=sys.stderr)
    raise SystemExit(2)
if timeout < 0:
    print("Error: --timeout must be a non-negative number", file=sys.stderr)
    raise SystemExit(2)
agent_filter = sys.argv[4]
run_filter = sys.argv[5]
deadline = None if timeout == 0 else time.monotonic() + timeout


def truthy(value):
    if value is True:
        return True
    return str(value).strip().lower() in {"true", "1", "yes", "on"}


def event_matches(event):
    if agent_filter and str(event.get("agent_id", "")) != agent_filter:
        return None
    if run_filter and str(event.get("run_id", "")) != run_filter:
        return None
    payload = event.get("payload")
    if not isinstance(payload, dict):
        payload = {}
    event_type = event.get("type")
    if event_type == "loop.stopped" and payload.get("reason") == "completion":
        return (
            f"event loop.stopped completion "
            f"run_id={event.get('run_id', '')} agent={event.get('agent_id', '')} "
            f"gate={payload.get('gate', '')}"
        )
    if event_type == "convergence.evaluated" and truthy(payload.get("passed")):
        return (
            f"event convergence.evaluated passed "
            f"run_id={event.get('run_id', '')} agent={event.get('agent_id', '')} "
            f"gate={payload.get('gate', '')}"
        )
    return None


def check_events():
    if not events_path.exists():
        return None
    try:
        lines = events_path.read_text(encoding="utf-8", errors="ignore").splitlines()
    except OSError:
        return None
    for line in reversed(lines):
        try:
            event = json.loads(line)
        except json.JSONDecodeError:
            continue
        matched = event_matches(event)
        if matched:
            return matched
    return None


def check_convergence_tsv():
    # convergence.tsv has no run_id column, so do not use it to prove a
    # run-specific wait. events.jsonl is the authoritative run-scoped source.
    if run_filter or not convergence_path.exists():
        return None
    try:
        rows = list(csv.DictReader(convergence_path.open(newline="", encoding="utf-8"), delimiter="\t"))
    except (OSError, csv.Error):
        return None
    for row in reversed(rows):
        if agent_filter and row.get("agent") != agent_filter:
            continue
        if truthy(row.get("passed")):
            return (
                f"convergence.tsv passed "
                f"agent={row.get('agent', '')} iteration={row.get('iteration', '')} "
                f"gate={row.get('gate', '')}"
            )
    return None


while True:
    matched = check_events() or check_convergence_tsv()
    if matched:
        print(f"Convergence observed: {matched}")
        raise SystemExit(0)
    if deadline is not None and time.monotonic() >= deadline:
        print("Timed out waiting for convergence", file=sys.stderr)
        raise SystemExit(124)
    time.sleep(0.25)
PY
}

cmd_stop() {
    local on_converge=false timeout=0 agent="" run_id=""
    while [[ $# -gt 0 ]]; do
